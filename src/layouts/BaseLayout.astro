---
import "@/styles/starwind.css";
import { Font } from 'astro:assets';
import { t, isRtl, type Locale } from '@/lib/i18n';
import SEOHead from '@/components/seo/SEOHead.astro';
import JsonLd from '@/components/seo/JsonLd.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: Locale;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  lang = 'fr',
  title,
  description = '',
  canonicalPath,
  ogImage,
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
  jsonLd,
} = Astro.props;
const pageTitle = title || t('footer.brandName', lang);
const dir = isRtl(lang) ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1a1a2e" />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <SEOHead
      title={pageTitle}
      description={description}
      lang={lang}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
    />
    {jsonLd && <JsonLd data={jsonLd} />}
    <Font cssVariable="--font-playfair" />
    <Font cssVariable="--font-cormorant" />
    <Font cssVariable="--font-manrope" />
  </head>
  <body class="bg-background text-foreground antialiased">
    <slot />
    <script is:inline>
      // Theme: apply saved preference or system default before paint
      (function () {
        const saved = localStorage.getItem('colorTheme') || localStorage.getItem('theme');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </body>
</html>
