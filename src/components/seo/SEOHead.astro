---
import { LOCALES, type Locale } from '@/lib/i18n';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
}

const {
  title,
  description,
  lang,
  canonicalPath,
  ogImage = '/og-default.jpg',
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  author,
} = Astro.props;

const siteUrl = (import.meta.env.SITE_URL || 'https://lesrochersblancs.fr').replace(/\/$/, '');
const currentPath = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = `${siteUrl}${currentPath}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

// Build alternate paths for hreflang
const pathWithoutLang = currentPath.replace(/^\/(fr|en|ar|zh)(\/|$)/, '/');
const hreflangs = LOCALES.map((locale) => ({
  locale,
  href: `${siteUrl}/${locale}${pathWithoutLang === '/' ? '/' : pathWithoutLang}`,
}));

const ogLocaleMap: Record<Locale, string> = {
  fr: 'fr_FR',
  en: 'en_US',
  ar: 'ar_SA',
  zh: 'zh_CN',
};
---

<!-- Canonical -->
<link rel="canonical" href={canonicalUrl} />

<!-- Hreflang alternates -->
{hreflangs.map(({ locale, href }) => (
  <link rel="alternate" hreflang={locale} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={`${siteUrl}/fr/`} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:locale" content={ogLocaleMap[lang]} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content="Les Rochers Blancs" />
{LOCALES.filter(l => l !== lang).map(l => (
  <meta property="og:locale:alternate" content={ogLocaleMap[l]} />
))}

<!-- Article-specific OG -->
{ogType === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{ogType === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{ogType === 'article' && author && (
  <meta property="article:author" content={author} />
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Robots -->
{noindex && <meta name="robots" content="noindex, nofollow" />}
