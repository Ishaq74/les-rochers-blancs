---
import { Icon } from 'astro-icon/components';
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import { getSetting } from '@/lib/settings';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const currentYear = new Date().getFullYear();

// Fetch from DB site_settings with i18n fallback
const [brandName, phone, email, address, instagramUrl, facebookUrl] = await Promise.all([
  getSetting('brand_name', 'footer.brandName', lang),
  getSetting('contact_phone', 'contact.phoneValue', lang),
  getSetting('contact_email', 'contact.emailValue', lang),
  getSetting('contact_address', 'contact.addressValue', lang),
  getSetting('social_instagram', 'footer.instagramUrl', lang),
  getSetting('social_facebook', 'footer.facebookUrl', lang),
]);
const isValidExternalUrl = (url: string) => /^https?:\/\//i.test(url);
---

<footer class="bg-primary text-primary-foreground" role="contentinfo">
  <!-- Gold accent line -->
  <div class="footer-accent-line"></div>
  <div class="container-wide mx-auto section-padding">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <h3 class="font-serif text-2xl font-bold mb-4">{brandName}</h3>
        <p class="text-primary-foreground/80 max-w-md mb-6">
          {t('hero.tagline', lang)}
        </p>
        {(isValidExternalUrl(instagramUrl) || isValidExternalUrl(facebookUrl)) && (
          <div class="flex gap-4">
            {isValidExternalUrl(instagramUrl) && (
              <a
                href={instagramUrl}
                class="w-10 h-10 rounded-full bg-primary-foreground/10 flex items-center justify-center hover:bg-accent hover:text-accent-foreground transition-colors"
                aria-label={t('footer.instagramLabel', lang)}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name="mdi:instagram" size={20} />
              </a>
            )}
            {isValidExternalUrl(facebookUrl) && (
              <a
                href={facebookUrl}
                class="w-10 h-10 rounded-full bg-primary-foreground/10 flex items-center justify-center hover:bg-accent hover:text-accent-foreground transition-colors"
                aria-label={t('footer.facebookLabel', lang)}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name="mdi:facebook" size={20} />
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Contact Info -->
      <div>
        <h4 class="font-serif text-lg font-semibold mb-4">{t('contact.title', lang)}</h4>
        <address class="not-italic space-y-3">
          <div class="flex items-start gap-3">
            <Icon name="mdi:map-marker" size={20} />
            <span class="text-primary-foreground/80">{address}</span>
          </div>
          <div class="flex items-center gap-3">
            <Icon name="mdi:phone" size={20} />
            <span class="text-primary-foreground/80">{phone}</span>
          </div>
          <div class="flex items-center gap-3">
            <Icon name="mdi:email" size={20} />
            <span class="text-primary-foreground/80">{email}</span>
          </div>
        </address>
      </div>

      <!-- Quick Links -->
      <nav aria-label={t('footer.quickLinksLabel', lang)}>
        <h4 class="font-serif text-lg font-semibold mb-4">{t('footer.quickLinksLabel', lang)}</h4>
        <ul class="space-y-2">
          <li>
            <a href="#rooms" class="text-primary-foreground/80 hover:text-accent transition-colors">
              {t('nav.rooms', lang)}
            </a>
          </li>
          <li>
            <a href="#restaurant" class="text-primary-foreground/80 hover:text-accent transition-colors">
              {t('nav.restaurant', lang)}
            </a>
          </li>
          <li>
            <a href="#menu" class="text-primary-foreground/80 hover:text-accent transition-colors">
              {t('nav.menu', lang)}
            </a>
          </li>
          <li>
            <a href="#access" class="text-primary-foreground/80 hover:text-accent transition-colors">
              {t('nav.access', lang)}
            </a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-primary-foreground/20 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-primary-foreground/60 text-sm">
        &copy; {currentYear} {brandName}. {t('footer.rights', lang)}.
      </p>
      <div class="flex gap-6 text-sm">
        <a href={`/${lang}/legal#section-0`} class="text-primary-foreground/60 hover:text-accent transition-colors">
          {t('footer.legal', lang)}
        </a>
        <a href={`/${lang}/legal#section-1`} class="text-primary-foreground/60 hover:text-accent transition-colors">
          {t('footer.privacy', lang)}
        </a>
      </div>
    </div>
  </div>
</footer>
