---
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import { Sheet, SheetTrigger, SheetContent, SheetHeader, SheetTitle } from '@/components/starwind/sheet';
import { Dropdown, DropdownTrigger, DropdownContent, DropdownItem } from '@/components/starwind/dropdown';
import { ThemeToggle } from '@/components/starwind/theme-toggle';
import { Icon } from 'astro-icon/components';
import { cms, getSetting } from '@/lib/settings';

interface Props {
  lang: Locale;
  opaqueNavbar?: boolean;
}

const { lang, opaqueNavbar = false } = Astro.props;

const [brandName, navHome, navHotel, navRestaurant, navMenu, navAccess] = await Promise.all([
  getSetting('brand_name', 'footer.brandName', lang),
  cms('nav', 'home', lang, 'nav.home'),
  cms('nav', 'hotel', lang, 'nav.hotel'),
  cms('nav', 'restaurant', lang, 'nav.restaurant'),
  cms('nav', 'menu', lang, 'nav.menu'),
  cms('nav', 'access', lang, 'nav.access'),
]);

// Resolve anchor links: prefix with the home URL when not on the homepage
// so that /fr/legal#access navigates to /fr/#access instead of staying on the legal page.
const homeBase = `/${lang}/`;
const anchor = (id: string) => `${homeBase}#${id}`;

const navItems = [
  { label: navHome, href: anchor('hero') },
  { label: navHotel, href: anchor('rooms') },
  { label: navRestaurant, href: anchor('restaurant') },
  { label: navMenu, href: anchor('menu') },
  { label: navAccess, href: anchor('access') },
];

const languages = [
  { code: 'fr', name: 'Français', flag: 'circle-flags:fr' },
  { code: 'en', name: 'English', flag: 'circle-flags:uk' },
  { code: 'ar', name: 'العربية', flag: 'circle-flags:sa' },
  { code: 'zh', name: '中文', flag: 'circle-flags:cn' },
];

---

<nav
  id="site-navbar"
  data-site-navbar="true"
  data-navbar-opaque={opaqueNavbar ? 'true' : 'false'}
  class:list={[
    'fixed top-0 left-0 right-0 z-50 transition-all duration-500',
    opaqueNavbar ? 'navbar-glass shadow-medium' : 'bg-transparent',
  ]}
>
  <div class="container-wide mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={anchor('hero')} class="flex items-center gap-3" aria-label={t('nav.home', lang)}>
        <span class="font-serif text-2xl font-bold tracking-wide navbar-logo-text text-snow">
          {brandName}
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            data-nav-anchor
            class="font-medium transition-colors hover:text-accent navbar-link text-snow"
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <Dropdown>
          <DropdownTrigger class="navbar-action-btn text-snow hover:bg-snow/10 rounded-md size-11 inline-flex items-center justify-center" aria-label={t('nav.language', lang)}>
            <Icon name="mdi:translate" />
          </DropdownTrigger>
          <DropdownContent align="end" class="min-w-40">
            {languages.map((l) => (
              <DropdownItem
                as="a"
                href={`/${l.code}/`}
                class:list={['gap-2 text-sm', { 'bg-accent/10': lang === l.code }]}
              >
                <Icon name={l.flag} />
                <span>{l.name}</span>
              </DropdownItem>
            ))}
          </DropdownContent>
        </Dropdown>

        <!-- Theme Toggle -->
        <ThemeToggle class="navbar-action-btn text-snow hover:bg-snow/10 border-0" />

        <!-- Mobile Menu Toggle -->
        <Sheet>
          <SheetTrigger class="lg:hidden navbar-action-btn text-snow hover:bg-snow/10 rounded-md size-11 inline-flex items-center justify-center" aria-label={t('nav.menuToggle', lang)}>
            <Icon name="mdi:menu" />
          </SheetTrigger>
          <SheetContent side="right">
            <SheetHeader>
              <SheetTitle>{brandName}</SheetTitle>
            </SheetHeader>
            <div class="flex flex-col gap-4 px-4 py-6">
              {navItems.map((item) => (
                <a
                  href={item.href}
                  data-nav-anchor
                  class="text-foreground font-medium py-2 hover:text-accent transition-colors"
                  data-sheet-nav-link
                >
                  {item.label}
                </a>
              ))}
            </div>
          </SheetContent>
        </Sheet>
      </div>
    </div>
  </div>
</nav>

<script>
  // Handle navbar scroll state
  const navbar = document.getElementById('site-navbar');
  if (navbar) {
    const alwaysOpaque = navbar.dataset.navbarOpaque === 'true';
    let ticking = false;
    const update = () => {
      if (alwaysOpaque) {
        navbar.classList.add('navbar-glass', 'shadow-medium');
        navbar.classList.remove('bg-transparent');
        ticking = false;
        return;
      }
      const scrolled = window.scrollY > 50;
      navbar.classList.toggle('navbar-glass', scrolled);
      navbar.classList.toggle('shadow-medium', scrolled);
      navbar.classList.toggle('bg-transparent', !scrolled);
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
    update();
  }

  // Close sheet on nav link click
  document.querySelectorAll('[data-sheet-nav-link]').forEach((link) => {
    link.addEventListener('click', () => {
      const closeBtn = document.querySelector('[data-slot="sheet-content"] [data-slot="sheet-close"]');
      if (closeBtn instanceof HTMLElement) closeBtn.click();
    });
  });

  // Smooth scroll for anchor links when already on the homepage.
  // Links are of the form "/{lang}/#section" — if we're already on that origin+pathname,
  // intercept the click and scroll smoothly instead of doing a full navigation.
  function initNavAnchorSmooth() {
    document.querySelectorAll<HTMLAnchorElement>('[data-nav-anchor]').forEach((link) => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href') ?? '';
        const hashIdx = href.indexOf('#');
        if (hashIdx === -1) return;
        const path = href.slice(0, hashIdx);
        const hash = href.slice(hashIdx + 1);
        // Only intercept if we're already on the target page
        if (path && window.location.pathname.replace(/\/$/, '') !== path.replace(/\/$/, '')) return;
        e.preventDefault();
        const target = document.getElementById(hash);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth' });
          history.replaceState(null, '', `#${hash}`);
        }
      });
    });
  }

  initNavAnchorSmooth();
  document.addEventListener('astro:after-swap', initNavAnchorSmooth);
</script>
