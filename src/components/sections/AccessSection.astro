---
import { Icon } from 'astro-icon/components';
import type { Locale } from '@/lib/i18n';
import { cms, getSetting } from '@/lib/settings';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// CMS-driven content with i18n fallback
const [accessTitle, accessSubtitle] = await Promise.all([
  cms('access', 'title', lang),
  cms('access', 'subtitle', lang),
]);

const accessItemDefs = [
  { key: 'bus', icon: 'mdi:bus' },
  { key: 'car', icon: 'mdi:car' },
  { key: 'gps', icon: 'mdi:map-marker' },
] as const;

const accessItems = await Promise.all(
  accessItemDefs.map(async (item) => ({
    icon: item.icon,
    title: await cms('access', `${item.key}.title`, lang, `access.${item.key}.title`),
    description: await cms('access', `${item.key}.description`, lang, `access.${item.key}.description`),
  }))
);

// Map URL from site settings
const mapQuery = await getSetting('map_query', '', lang) || 'Les%20Rochers%20Blancs%20Semnoz';
const mapLabel = await cms('access', 'gps.title', lang, 'access.gps.title');
---

<section id="access" class="relative overflow-hidden section-padding bg-primary text-primary-foreground">
  <div class="container-wide mx-auto">
    <!-- Watermark -->
    <Icon name="mdi:map-marker" size={280} class="section-watermark top-right text-primary-foreground" aria-hidden="true" />

    <!-- Header -->
    <div class="text-center mb-section animate-fade-up">
      <h2 class="heading-section mb-3 !text-primary-foreground">
        {accessTitle}
      </h2>
      <div class="heading-accent-bar"><span class="heading-accent-bar-diamond"></span></div>
      <p class="section-subtitle !text-primary-foreground/70">
        {accessSubtitle}
      </p>
    </div>

    <!-- Access content: left list + right map -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-section items-start">
      <div class="space-y-4">
        {accessItems.map((item, index) => (
          <div
            class="bg-card rounded-xl p-6 border border-border/50 shadow-soft hover:shadow-card-hover hover:-translate-y-1 transition-all duration-300 animate-fade-up"
            style={`animation-delay: ${index * 0.12}s;`}
          >
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-accent/20 flex items-center justify-center shrink-0">
                <Icon name={item.icon} size={24} class="text-accent" />
              </div>
              <div>
                <h3 class="heading-card mb-2">
                  {item.title}
                </h3>
                <p class="text-muted-foreground text-sm leading-relaxed">
                  {item.description}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-card rounded-xl border border-border/50 shadow-soft overflow-hidden animate-fade-up" style="animation-delay: 0.2s;">
        <div class="px-5 py-4 border-b border-border/50 bg-background/50 flex items-center gap-2">
          <Icon name="mdi:map-marker" size={16} class="text-accent" />
          <span class="text-sm font-medium text-foreground">{mapLabel}</span>
        </div>
        <div class="aspect-[4/3] w-full">
          <iframe
            title={`Carte - ${mapLabel}`}
            src={`https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&output=embed`}
            class="w-full h-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
