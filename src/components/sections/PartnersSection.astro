---
import { Icon } from 'astro-icon/components';
import type { Locale } from '@/lib/i18n';
import { db } from '@/db';
import { partners as partnersTable } from '@/db/schema';
import { eq, asc } from 'drizzle-orm';
import { cms } from '@/lib/settings';
import { DEFAULT_PARTNER_LOGOS, normalizeSlug } from '@/lib/default-media';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const fallbackPartners = [
  { name: 'Alpes Bivouac', logoUrl: DEFAULT_PARTNER_LOGOS['alpes-bivouac'], websiteUrl: null },
  { name: 'AMT Organisation', logoUrl: DEFAULT_PARTNER_LOGOS['amt-organisation'], websiteUrl: null },
  { name: 'Annecy Aventure', logoUrl: DEFAULT_PARTNER_LOGOS['annecy-aventure'], websiteUrl: null },
  { name: 'Annecy Takamaka', logoUrl: DEFAULT_PARTNER_LOGOS['annecy-takamaka'], websiteUrl: null },
  { name: 'Que Faire a Annecy', logoUrl: DEFAULT_PARTNER_LOGOS['que-faire-a-annecy'], websiteUrl: null },
  { name: 'Semnoz', logoUrl: DEFAULT_PARTNER_LOGOS.semnoz, websiteUrl: null },
];

let partners: { name: string; logoUrl: string | null; websiteUrl: string | null }[] = [];
try {
  const rows = await db.select().from(partnersTable)
    .where(eq(partnersTable.isActive, true))
    .orderBy(asc(partnersTable.sortOrder));
  partners = rows.length > 0
    ? rows.map((row) => {
        const normalized = normalizeSlug(row.slug || row.name || '');
        return {
          ...row,
          logoUrl: row.logoUrl || DEFAULT_PARTNER_LOGOS[normalized] || null,
        };
      })
    : fallbackPartners;
} catch {
  partners = fallbackPartners;
}

const [partnersTitle, partnersDescription] = await Promise.all([
  cms('partners', 'title', lang, 'partners.title'),
  cms('partners', 'description', lang, 'partners.description'),
]);
---

<section id="partners" class="relative overflow-hidden section-padding bg-cream">
  <div class="container-wide mx-auto">
    <!-- Watermark -->
    <Icon name="mdi:handshake" size={280} class="section-watermark top-right text-foreground" aria-hidden="true" />

    <!-- Header -->
    <div class="text-center mb-section animate-fade-up">
      <h2 class="heading-section mb-3">
        {partnersTitle}
      </h2>
      <div class="heading-accent-bar"><span class="heading-accent-bar-diamond"></span></div>
      <p class="section-subtitle max-w-2xl mx-auto">
        {partnersDescription}
      </p>
    </div>

    <!-- Partner logo grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-item">
      {partners.map((partner, i) => (
        <div
          class="partner-logo card-elevated p-3 aspect-3/2 animate-fade-up"
          style={`animation-delay: ${i * 0.07}s;`}
        >
          {partner.websiteUrl ? (
            <a href={partner.websiteUrl} target="_blank" rel="noopener noreferrer"
              class="w-full h-full rounded-lg flex items-center justify-center p-3">
              <img
                src={partner.logoUrl ?? ''}
                alt={partner.name}
                class="partner-logo-img w-full h-full object-contain transition-all duration-300"
                loading="lazy"
              />
            </a>
          ) : (
            <div class="w-full h-full rounded-lg flex items-center justify-center p-3">
              <img
                src={partner.logoUrl ?? ''}
                alt={partner.name}
                class="partner-logo-img w-full h-full object-contain transition-all duration-300"
                loading="lazy"
              />
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
