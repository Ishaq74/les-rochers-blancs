---
import { Icon } from 'astro-icon/components';
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import alpesBivouac from '@/assets/partners/alpes_bivouac.webp';
import amtOrganisation from '@/assets/partners/amt-organisation.webp';
import annecyAventure from '@/assets/partners/annecy_aventure.webp';
import annecyTakamaka from '@/assets/partners/Annecy_Takamaka.webp';
import queFaireAnnecy from '@/assets/partners/que-faire-a-annecy.webp';
import semnoz from '@/assets/partners/Semnoz.webp';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const partners = [
  { src: alpesBivouac.src, alt: 'Alpes Bivouac' },
  { src: amtOrganisation.src, alt: 'AMT Organisation' },
  { src: annecyAventure.src, alt: 'Annecy Aventure' },
  { src: annecyTakamaka.src, alt: 'Annecy Takamaka' },
  { src: queFaireAnnecy.src, alt: 'Que Faire a Annecy' },
  { src: semnoz.src, alt: 'Semnoz' },
] as const;

const logoSurfaceStyle = 'background-color: var(--background);';
---

<section id="partners" class="relative overflow-hidden section-padding bg-cream">
  <div class="container-wide mx-auto">
    <!-- Watermark -->
    <Icon name="mdi:handshake" size={280} class="section-watermark top-right text-foreground" aria-hidden="true" />

    <!-- Header -->
    <div class="text-center mb-section animate-fade-up">
      <h2 class="heading-section mb-3">
        {t('partners.title', lang)}
      </h2>
      <div class="heading-accent-bar"><span class="heading-accent-bar-diamond"></span></div>
      <p class="section-subtitle max-w-2xl mx-auto">
        {t('partners.description', lang)}
      </p>
    </div>

    <!-- Partner logo grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-item">
      {partners.map((partner, i) => (
        <div
          class="partner-logo card-elevated p-3 aspect-[3/2] animate-fade-up"
          style={`animation-delay: ${i * 0.07}s;`}
        >
          <div
            class="w-full h-full rounded-lg flex items-center justify-center p-3"
            style={logoSurfaceStyle}
          >
            <img
              src={partner.src}
              alt={partner.alt}
              class="w-full h-full object-contain"
              loading="lazy"
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
