---
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import { Carousel, CarouselContent, CarouselItem, CarouselPrevious, CarouselNext } from '@/components/starwind/carousel';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import roomImage from '@/assets/room-suite.jpg';
import summerImage from '@/assets/season-summer.jpg';
import winterImage from '@/assets/season-winter.jpg';
import { db } from '@/db';
import { rooms as roomsTable, roomTranslations, roomExtras as roomExtrasTable, roomExtraTranslations } from '@/db/schema';
import { eq, asc } from 'drizzle-orm';
import { cms } from '@/lib/settings';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// ------- Fetch rooms from DB with i18n fallback -------
interface RoomDisplay { name: string; price: string }
interface ExtraDisplay { label: string }

let roomsData: RoomDisplay[] = [];
let extrasData: ExtraDisplay[] = [];
let useFallback = false;

try {
  const [dbRooms, dbRoomTrans, dbExtras, dbExtraTrans] = await Promise.all([
    db.select().from(roomsTable).where(eq(roomsTable.isActive, true)).orderBy(asc(roomsTable.sortOrder)),
    db.select().from(roomTranslations).where(eq(roomTranslations.locale, lang)),
    db.select().from(roomExtrasTable).where(eq(roomExtrasTable.isActive, true)).orderBy(asc(roomExtrasTable.sortOrder)),
    db.select().from(roomExtraTranslations).where(eq(roomExtraTranslations.locale, lang)),
  ]);

  if (dbRooms.length > 0) {
    const transMap = new Map(dbRoomTrans.map(tr => [tr.roomId, tr]));
    roomsData = dbRooms.map(r => ({
      name: transMap.get(r.id)?.name ?? r.slug,
      price: r.pricePerNight,
    }));

    const extraTransMap = new Map(dbExtraTrans.map(tr => [tr.extraId, tr]));
    extrasData = dbExtras.map(e => ({
      label: extraTransMap.get(e.id)?.label ?? (e.price ? `${e.slug} — ${e.price}€` : e.slug),
    }));
  } else {
    useFallback = true;
  }
} catch {
  useFallback = true;
}

// Fallback to i18n keys
if (useFallback) {
  const roomKeys = ['single', 'double1', 'double2', 'triple', 'quad', 'five'] as const;
  const extraKeys = ['breakfast', 'halfBoard', 'halfBoardChild', 'fullBoard', 'singleSupplement', 'fullBoardChild', 'taxAndDog'] as const;
  roomsData = roomKeys.map(key => ({
    name: t(`hotel.rooms.${key}.name`, lang),
    price: t(`hotel.rooms.${key}.price`, lang),
  }));
  extrasData = extraKeys.map(key => ({
    label: t(`hotel.extras.${key}`, lang),
  }));
}

const [hotelTitle, hotelSubtitle, hotelDescription, hotelDescription2, hotelGroupNote, hotelClosingNote, hotelPricingTitle, hotelExtrasTitle] = await Promise.all([
  cms('hotel', 'title', lang, 'hotel.title'),
  cms('hotel', 'subtitle', lang, 'hotel.subtitle'),
  cms('hotel', 'description', lang, 'hotel.description'),
  cms('hotel', 'description2', lang, 'hotel.description2'),
  cms('hotel', 'groupNote', lang, 'hotel.groupNote'),
  cms('hotel', 'closingNote', lang, 'hotel.closingNote'),
  cms('hotel', 'pricingTitle', lang, 'hotel.pricingTitle'),
  cms('hotel', 'extrasTitle', lang, 'hotel.extras.title'),
]);

const carouselImages = [
  { src: roomImage, alt: hotelTitle },
  { src: summerImage, alt: hotelTitle },
  { src: winterImage, alt: hotelTitle },
];
---

<section id="rooms" class="relative overflow-hidden section-padding bg-background">
  <div class="container-wide mx-auto">
    <!-- Watermark -->
    <Icon name="mdi:bed" size={280} class="section-watermark top-right text-foreground" aria-hidden="true" />

    <!-- Header -->
    <div class="text-center mb-section animate-fade-up">
      <h2 class="heading-section mb-3">
        {hotelTitle}
      </h2>
      <div class="heading-accent-bar"><span class="heading-accent-bar-diamond"></span></div>
      <p class="font-serif text-xl text-muted-foreground italic">
        {hotelSubtitle}
      </p>
    </div>

    <!-- Main Grid: Carousel Left + Content Right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-section items-stretch">
      <!-- Carousel Left -->
      <div class="flex items-center animate-fade-up">
        <Carousel class="w-full" opts={{ loop: true }}>
          <CarouselContent>
            {carouselImages.map((img) => (
              <CarouselItem>
                <div class="relative w-full aspect-3/4 overflow-hidden rounded-xl shadow-large">
                  <Image
                    src={img.src}
                    alt={img.alt}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-700 ease-out"
                    widths={[400, 640, 800]}
                    sizes="(max-width: 1024px) 100vw, 50vw"
                  />
                </div>
              </CarouselItem>
            ))}
          </CarouselContent>
          <CarouselPrevious class="size-10" />
          <CarouselNext class="size-10" />
        </Carousel>
      </div>

      <!-- Content Right -->
      <div class="flex flex-col justify-between animate-fade-up" style="animation-delay: 0.2s;">
        <!-- Description -->
        <div class="mb-8">
          <p class="text-muted-foreground leading-relaxed mb-4 text-base">
            {hotelDescription}
          </p>
          <p class="text-muted-foreground leading-relaxed mb-6 text-base">
            {hotelDescription2}
          </p>
          <div class="bg-accent/10 rounded-lg p-4 mb-6">
            <div class="flex items-start gap-3">
              <Icon name="mdi:information-outline" />
              <p class="text-sm text-muted-foreground">
                {hotelGroupNote}
              </p>
            </div>
          </div>
          <p class="text-sm text-muted-foreground italic">
            {hotelClosingNote}
          </p>
        </div>

        <!-- Rooms Pricing - 2 Column Grid -->
        <div>
          <h3 class="heading-subsection mb-6">
            {hotelPricingTitle}
          </h3>
          <div class="grid grid-cols-2 gap-item">
            {roomsData.map((room) => (
              <div class="card-elevated p-4">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-8 h-8 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                    <Icon name="mdi:account-group" />
                  </div>
                </div>
                <p class="text-sm font-medium text-foreground mb-2">
                  {room.name}
                </p>
                <p class="text-lg font-bold text-gradient-gold font-serif">
                  {room.price}€
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Extras -->
    <div class="my-section animate-fade-up">
      <div class="bg-secondary rounded-xl p-8">
        <h3 class="heading-subsection mb-6 flex items-center gap-2">
          <Icon name="mdi:check-circle" />
          {hotelExtrasTitle}
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-item">
          {extrasData.map((extra) => (
            <p class="text-sm text-muted-foreground flex items-start gap-2">
              <span class="text-accent mt-1.5 shrink-0">•</span>
              {extra.label}
            </p>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
