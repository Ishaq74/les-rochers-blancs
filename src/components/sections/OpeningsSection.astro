---
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import summerImage from '@/assets/season-summer.jpg';
import winterImage from '@/assets/season-winter.jpg';
import { db } from '@/db';
import { openings as openingsTable, openingTranslations } from '@/db/schema';
import { eq, asc, desc } from 'drizzle-orm';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// ------- Date helpers -------
function isDateInRange(startStr: string, endStr: string): boolean {
  const now = new Date();
  const start = new Date(startStr);
  const end = new Date(endStr);
  return now >= start && now <= end;
}

// ------- Season data -------
interface SeasonData {
  key: 'summer' | 'winter';
  variant: 'primary' | 'light';
  icon: string;
  image: ImageMetadata;
  title: string;
  restaurantLabel: string;
  restaurantDates: string;
  restaurantOpen: boolean;
  hotelLabel: string;
  hotelDates: string;
  hotelOpen: boolean;
  closedDays: string;
  isSeasonActive: boolean;
}

let seasons: SeasonData[] = [];
let useFallback = false;

try {
  const [dbOpenings, dbTrans] = await Promise.all([
    db.select().from(openingsTable)
      .where(eq(openingsTable.isActive, true))
      .orderBy(desc(openingsTable.year), asc(openingsTable.sortOrder)),
    db.select().from(openingTranslations)
      .where(eq(openingTranslations.locale, lang)),
  ]);

  if (dbOpenings.length > 0) {
    const transMap = new Map(dbTrans.map(tr => [tr.openingId, tr]));
    const imageMap = { summer: summerImage, winter: winterImage };
    const variantMap = { summer: 'primary' as const, winter: 'light' as const };
    const iconMap = { summer: 'mdi:weather-sunny', winter: 'mdi:snowflake' };

    // Take the most recent entry per season
    const seen = new Set<string>();
    for (const opening of dbOpenings) {
      if (seen.has(opening.season)) continue;
      seen.add(opening.season);

      const tr = transMap.get(opening.id);
      const restaurantOpen = isDateInRange(opening.restaurantStartDate, opening.restaurantEndDate);
      const hotelOpen = isDateInRange(opening.hotelStartDate, opening.hotelEndDate);

      seasons.push({
        key: opening.season,
        variant: variantMap[opening.season],
        icon: iconMap[opening.season],
        image: imageMap[opening.season],
        title: tr?.title ?? (opening.season === 'summer' ? 'Été' : 'Hiver'),
        restaurantLabel: tr?.restaurantLabel ?? 'Restaurant',
        restaurantDates: tr?.restaurantDates ?? `${opening.restaurantStartDate} — ${opening.restaurantEndDate}`,
        restaurantOpen,
        hotelLabel: tr?.hotelLabel ?? 'Hôtel',
        hotelDates: tr?.hotelDates ?? `${opening.hotelStartDate} — ${opening.hotelEndDate}`,
        hotelOpen,
        closedDays: tr?.closedDays ?? '',
        isSeasonActive: restaurantOpen || hotelOpen,
      });
    }
    // Ensure summer first
    seasons.sort((a) => (a.key === 'summer' ? -1 : 1));
  } else {
    useFallback = true;
  }
} catch {
  useFallback = true;
}

// Fallback to i18n (fragile DD/MM/YYYY parsing kept for backwards compat)
if (useFallback) {
  function parseDateFromText(text: string): Date | null {
    const match = text.match(/(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
    if (!match) return null;
    const day = parseInt(match[1], 10);
    const month = parseInt(match[2], 10) - 1;
    let year = parseInt(match[3], 10);
    if (year < 100) year += 2000;
    return new Date(year, month, day);
  }

  function isCurrentlyOpenFallback(dateText: string): boolean {
    const dates = dateText.match(/\d{1,2}\/\d{1,2}\/\d{2,4}/g);
    if (!dates || dates.length === 0) return false;
    const start = parseDateFromText(dates[0]);
    const end = parseDateFromText(dates[dates.length - 1]);
    if (!start || !end) return false;
    const now = new Date();
    return now >= start && now <= end;
  }

  function buildFallbackSeason(key: 'summer' | 'winter', variant: 'primary' | 'light', icon: string, image: ImageMetadata): SeasonData {
    const restaurantDates = t(`openings.${key}.restaurantDates`, lang);
    const hotelDates = t(`openings.${key}.hotelDates`, lang);
    const restaurantOpen = isCurrentlyOpenFallback(restaurantDates);
    const hotelOpen = isCurrentlyOpenFallback(hotelDates);
    return {
      key, variant, icon, image,
      title: t(`openings.${key}.title`, lang),
      restaurantLabel: t(`openings.${key}.restaurantLabel`, lang),
      restaurantDates,
      restaurantOpen,
      hotelLabel: t(`openings.${key}.hotelLabel`, lang),
      hotelDates,
      hotelOpen,
      closedDays: t(`openings.${key}.closedDays`, lang),
      isSeasonActive: restaurantOpen || hotelOpen,
    };
  }

  seasons = [
    buildFallbackSeason('summer', 'primary', 'mdi:weather-sunny', summerImage),
    buildFallbackSeason('winter', 'light', 'mdi:snowflake', winterImage),
  ];
}

const openLabel = t('openings.statusOpen', lang);
const closedLabel = t('openings.statusClosed', lang);
const openingLabel = t('openings.openingLabel', lang);
---

<section id="openings" class="relative overflow-hidden section-padding bg-secondary" aria-labelledby="openings-heading">
  <div class="container-wide mx-auto">
    <!-- Watermark -->
    <Icon name="mdi:calendar-clock" size={280} class="section-watermark top-right text-foreground" aria-hidden="true" />

    <div class="text-center mb-section animate-fade-up">
      <h2 id="openings-heading" class="heading-section">
        {t('openings.title', lang)}
      </h2>
      <div class="heading-accent-bar"><span class="heading-accent-bar-diamond"></span></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-section">
      {seasons.map((season) => {
        const isPrimary = season.variant === 'primary';
        const cardClasses = isPrimary
          ? 'bg-primary text-primary-foreground'
          : 'bg-muted text-foreground border border-border/50';
        const badgeBg = isPrimary ? 'bg-accent text-accent-foreground' : 'bg-primary text-primary-foreground';
        const textMuted = isPrimary ? 'text-primary-foreground/85' : 'text-muted-foreground';
        const alertBg = isPrimary ? 'bg-accent/20' : 'bg-primary/10';
        const alertIcon = isPrimary ? 'text-accent' : 'text-primary';

        return (
          <div
            class={`${cardClasses} rounded-2xl overflow-hidden shadow-lg border-2 animate-fade-up ${
              season.isSeasonActive ? 'ring-2 ring-green-400/50 border-green-400/40' : 'border-border/30'
            }`}
          >
            {/* Image */}
            <div class="relative h-48 overflow-hidden">
              <Image
                src={season.image}
                alt={season.title}
                class="w-full h-full object-cover"
                loading="lazy"
                widths={[400, 640]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              <div class={`absolute inset-0 ${isPrimary ? 'bg-primary/30' : 'bg-foreground/10'}`}></div>
              <div class="absolute bottom-3 left-4 flex items-center gap-2">
                <Icon name={season.icon} class={`size-7 ${isPrimary ? 'text-accent' : 'text-primary'}`} aria-hidden="true" />
                <h3 class={`heading-subsection ${isPrimary ? 'text-primary-foreground' : 'text-foreground'} drop-shadow-md`}>
                  {season.title}
                </h3>
              </div>
              <div class="absolute top-3 right-3">
                <span
                  class={`inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold ${
                    season.isSeasonActive
                      ? 'bg-green-500/90 text-white'
                      : isPrimary
                        ? 'bg-black/30 text-primary-foreground'
                        : 'bg-background/90 text-muted-foreground'
                  }`}
                >
                  {season.isSeasonActive ? (
                    <Icon name="mdi:check-circle" class="size-3.5" aria-hidden="true" />
                  ) : (
                    <Icon name="mdi:close-circle" class="size-3.5" aria-hidden="true" />
                  )}
                  {season.isSeasonActive ? openLabel : closedLabel}
                </span>
              </div>
            </div>

            {/* Content */}
            <div class="p-6 space-y-4">
              <p class={`font-semibold tracking-wider uppercase text-xs ${isPrimary ? 'text-accent' : 'text-primary'}`}>
                {openingLabel}
              </p>

              {/* Restaurant */}
              <div>
                <div class="flex items-center gap-2 mb-1.5">
                  <span class={`inline-flex items-center gap-1.5 ${badgeBg} px-2.5 py-0.5 rounded text-xs font-semibold`}>
                    <Icon name="mdi:silverware-fork-knife" class="size-3.5" aria-hidden="true" />
                    {season.restaurantLabel}
                  </span>
                  {season.restaurantOpen ? (
                      <span class="inline-flex items-center gap-1 text-xs font-medium text-green-400" role="status">
                        <Icon name="mdi:check-circle" class="size-3.5" aria-hidden="true" />
                        {openLabel}
                      </span>
                    ) : (
                      <span class={`inline-flex items-center gap-1 text-xs font-medium ${isPrimary ? 'text-primary-foreground/50' : 'text-muted-foreground/70'}`} role="status">
                        <Icon name="mdi:close-circle" class="size-3.5" aria-hidden="true" />
                        {closedLabel}
                      </span>
                    )}
                </div>
                <p class={`${textMuted} text-sm`}>{season.restaurantDates}</p>
              </div>

              {/* Hotel */}
              <div>
                <div class="flex items-center gap-2 mb-1.5">
                  <span class={`inline-flex items-center gap-1.5 ${badgeBg} px-2.5 py-0.5 rounded text-xs font-semibold`}>
                    <Icon name="mdi:bed" class="size-3.5" aria-hidden="true" />
                    {season.hotelLabel}
                  </span>
                  {season.hotelOpen ? (
                      <span class="inline-flex items-center gap-1 text-xs font-medium text-green-400" role="status">
                        <Icon name="mdi:check-circle" class="size-3.5" aria-hidden="true" />
                        {openLabel}
                      </span>
                    ) : (
                      <span class={`inline-flex items-center gap-1 text-xs font-medium ${isPrimary ? 'text-primary-foreground/50' : 'text-muted-foreground/70'}`} role="status">
                        <Icon name="mdi:close-circle" class="size-3.5" aria-hidden="true" />
                        {closedLabel}
                      </span>
                    )}
                </div>
                <p class={`${textMuted} text-sm`}>{season.hotelDates}</p>
              </div>

              {/* Closed days warning */}
              <div class={`flex items-start gap-2 ${alertBg} rounded-lg p-3`} role="alert">
                <Icon name="mdi:alert" class={`size-4 ${alertIcon} mt-0.5 shrink-0`} aria-hidden="true" />
                <p class={`${textMuted} text-sm font-medium`}>
                  {season.closedDays}
                </p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
