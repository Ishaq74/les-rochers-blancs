---
import { Icon } from 'astro-icon/components';
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';
import { getSetting } from '@/lib/settings';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

// Fetch from DB site_settings with i18n fallback
const [phone, email, address, hours] = await Promise.all([
  getSetting('contact_phone', 'contact.phoneValue', lang),
  getSetting('contact_email', 'contact.emailValue', lang),
  getSetting('contact_address', 'contact.addressValue', lang),
  getSetting('contact_hours', 'contact.hoursValue', lang),
]);
---

<section id="contact" class="relative overflow-hidden section-padding bg-background" aria-labelledby="contact-heading">
  <div class="container-wide mx-auto">
    <!-- Watermark -->
    <Icon name="mdi:email-outline" class="section-watermark top-right text-foreground" size={280} aria-hidden="true" />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Info -->
      <div class="animate-fade-up">
        <h2 id="contact-heading" class="heading-section mb-3">
          {t('contact.title', lang)}
        </h2>
        <div class="heading-accent-bar mx-0!"><span class="heading-accent-bar-diamond"></span></div>
        <p class="section-subtitle mb-section">
          {t('contact.subtitle', lang)}
        </p>

        <address class="space-y-item not-italic">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <Icon name="mdi:map-marker" size={20} />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.addressLabel', lang)}</p>
              <p class="text-muted-foreground">{address}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <Icon name="mdi:phone" size={20} />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.phoneLabel', lang)}</p>
              <p class="text-muted-foreground">{phone}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <Icon name="mdi:email" size={20} />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.emailLabel', lang)}</p>
              <p class="text-muted-foreground">{email}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
              <Icon name="mdi:clock-outline" size={20} />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.hoursLabel', lang)}</p>
              <p class="text-muted-foreground">{hours}</p>
            </div>
          </div>
        </address>
      </div>

      <!-- Form -->
      <div class="card-elevated p-8 lg:p-10 animate-fade-up" style="animation-delay: 0.2s;">
        <div id="contact-success" class="hidden mb-6 rounded-lg border border-green-500/30 bg-green-500/10 p-4 text-green-700 dark:text-green-400" role="status">
          <p class="text-sm font-medium">{t('contact.form.success', lang)}</p>
        </div>
        <div id="contact-error" class="hidden mb-6 rounded-lg border border-red-500/30 bg-red-500/10 p-4 text-red-700 dark:text-red-400" role="alert">
          <p class="text-sm font-medium">{t('contact.form.error', lang)}</p>
        </div>
        <form id="contact-form" class="space-y-6" aria-label={t('contact.formLabel', lang)}>
          <input type="hidden" name="locale" value={lang} />
          <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div>
            <label for="contact-name" class="sr-only">{t('contact.form.name', lang)}</label>
            <input
              id="contact-name"
              type="text"
              name="name"
              required
              minlength={2}
              maxlength={200}
              placeholder={t('contact.form.name', lang)}
              class="input-elegant flex h-12 w-full rounded-md border border-border bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none"
            />
          </div>
          <div>
            <label for="contact-email" class="sr-only">{t('contact.form.email', lang)}</label>
            <input
              id="contact-email"
              type="email"
              name="email"
              required
              maxlength={300}
              placeholder={t('contact.form.email', lang)}
              class="input-elegant flex h-12 w-full rounded-md border border-border bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none"
            />
          </div>
          <div>
            <label for="contact-message" class="sr-only">{t('contact.form.message', lang)}</label>
            <textarea
              id="contact-message"
              name="message"
              required
              minlength={10}
              maxlength={5000}
              placeholder={t('contact.form.message', lang)}
              class="input-elegant flex min-h-37.5 w-full rounded-md border border-border bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="btn-gold inline-flex items-center justify-center h-12 font-semibold px-8 rounded-md w-full sm:w-auto"
          >
            {t('contact.form.send', lang)}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('contact-success')!;
  const errorEl = document.getElementById('contact-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    const formData = new FormData(form);
    const { error } = await actions.sendContact(formData);

    if (error) {
      errorEl.classList.remove('hidden');
    } else {
      successEl.classList.remove('hidden');
      form.reset();
    }
  });
</script>
