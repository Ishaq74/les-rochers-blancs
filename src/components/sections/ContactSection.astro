---
import { Icon } from 'astro-icon/components';
import { t } from '@/lib/i18n';
import type { Locale } from '@/lib/i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section id="contact" class="relative overflow-hidden section-padding bg-background" aria-labelledby="contact-heading">
  <div class="container-wide mx-auto">
    <!-- Watermark -->
    <Icon name="mdi:email-outline" size={280} class="section-watermark top-right text-foreground" aria-hidden="true" />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <!-- Info -->
      <div class="animate-fade-up">
        <h2 id="contact-heading" class="heading-section mb-3">
          {t('contact.title', lang)}
        </h2>
        <div class="heading-accent-bar !mx-0"><span class="heading-accent-bar-diamond"></span></div>
        <p class="section-subtitle mb-section">
          {t('contact.subtitle', lang)}
        </p>

        <address class="space-y-item not-italic">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
              <Icon name="mdi:map-marker" size={20} class="text-accent" />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.addressLabel', lang)}</p>
              <p class="text-muted-foreground">{t('contact.addressValue', lang)}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
              <Icon name="mdi:phone" size={20} class="text-accent" />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.phoneLabel', lang)}</p>
              <p class="text-muted-foreground">{t('contact.phoneValue', lang)}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
              <Icon name="mdi:email" size={20} class="text-accent" />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.emailLabel', lang)}</p>
              <p class="text-muted-foreground">{t('contact.emailValue', lang)}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
              <Icon name="mdi:clock-outline" size={20} class="text-accent" />
            </div>
            <div>
              <p class="font-semibold text-foreground mb-1">{t('contact.hoursLabel', lang)}</p>
              <p class="text-muted-foreground">{t('contact.hoursValue', lang)}</p>
            </div>
          </div>
        </address>
      </div>

      <!-- Form -->
      <div class="card-elevated p-8 lg:p-10 animate-fade-up" style="animation-delay: 0.2s;">
        <form class="space-y-6" aria-label={t('contact.formLabel', lang)}>
          <div>
            <input
              type="text"
              placeholder={t('contact.form.name', lang)}
              class="input-elegant flex h-12 w-full rounded-md border border-border bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none"
              aria-label={t('contact.form.name', lang)}
            />
          </div>
          <div>
            <input
              type="email"
              placeholder={t('contact.form.email', lang)}
              class="input-elegant flex h-12 w-full rounded-md border border-border bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none"
              aria-label={t('contact.form.email', lang)}
            />
          </div>
          <div>
            <textarea
              placeholder={t('contact.form.message', lang)}
              class="input-elegant flex min-h-[150px] w-full rounded-md border border-border bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none resize-none"
              aria-label={t('contact.form.message', lang)}
            ></textarea>
          </div>
          <button
            type="submit"
            class="btn-gold inline-flex items-center justify-center h-12 font-semibold px-8 rounded-md w-full sm:w-auto"
          >
            {t('contact.form.send', lang)}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
