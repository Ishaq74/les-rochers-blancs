---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import Footer from '@/components/layout/Footer.astro';
import { Badge } from '@/components/starwind/badge';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/starwind/tabs';
import { Accordion, AccordionContent, AccordionItem, AccordionTrigger } from '@/components/starwind/accordion';
import { t, getSection, type Locale } from '@/lib/i18n';
import { getSiteSettings } from '@/lib/settings';

export const prerender = false;

const { lang } = Astro.params as { lang: Locale };

const legal = getSection('legal', lang) as {
  eyebrow: string;
  heading: string;
  sections: Array<{
    id: string;
    title: string;
    intro?: string;
    items: Array<{ question: string; answer: string }>;
  }>;
};

const sections = legal.sections ?? [];
const firstTab = sections.length > 0 ? `section-0` : '';

const settings = await getSiteSettings();
const companyName = settings.get('brand_name') || t('footer.brandName', lang);
const legalIdentity = {
  companyForm: settings.get('legal_company_form') || 'A definir',
  siret: settings.get('legal_siret') || 'A definir',
  vat: settings.get('legal_vat') || 'A definir',
  rcs: settings.get('legal_rcs') || 'A definir',
  publishingDirector: settings.get('legal_publishing_director') || companyName,
  address: settings.get('contact_address') || 'A definir',
  phone: settings.get('contact_phone') || 'A definir',
  email: settings.get('contact_email') || 'A definir',
};

const pageTitle = `${legal.heading} — ${t('footer.brandName', lang)}`;
const description = legal.eyebrow;
---

<BaseLayout title={pageTitle} description={description} lang={lang} canonicalPath={`/${lang}/legal`}>
  <Navbar lang={lang} opaqueNavbar={true} />
  <main class="pt-24">
    <section class="mx-auto w-full max-w-5xl px-4 py-16 md:py-24">
      <div class="mb-12">
        <Badge variant="primary" size="sm">{legal.eyebrow}</Badge>
        <h1 class="font-heading mt-3 text-3xl font-semibold tracking-tight md:text-4xl lg:text-5xl">
          {legal.heading}
        </h1>
      </div>

      <div class="mb-10 rounded-2xl border border-border bg-card p-5 shadow-sm">
        <h2 class="text-lg font-semibold">{t('legal.identity.title', lang)}</h2>
        <div class="mt-4 grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
          <p><span class="font-medium">{t('legal.identity.companyName', lang)}:</span> {companyName}</p>
          <p><span class="font-medium">{t('legal.identity.companyForm', lang)}:</span> {legalIdentity.companyForm}</p>
          <p><span class="font-medium">{t('legal.identity.siret', lang)}:</span> {legalIdentity.siret}</p>
          <p><span class="font-medium">{t('legal.identity.vat', lang)}:</span> {legalIdentity.vat}</p>
          <p><span class="font-medium">{t('legal.identity.rcs', lang)}:</span> {legalIdentity.rcs}</p>
          <p><span class="font-medium">{t('legal.identity.publishingDirector', lang)}:</span> {legalIdentity.publishingDirector}</p>
          <p class="md:col-span-2"><span class="font-medium">{t('legal.identity.address', lang)}:</span> {legalIdentity.address}</p>
          <p><span class="font-medium">{t('legal.identity.phone', lang)}:</span> {legalIdentity.phone}</p>
          <p><span class="font-medium">{t('legal.identity.email', lang)}:</span> {legalIdentity.email}</p>
        </div>
      </div>

      <div class="min-h-96">
        <Tabs defaultValue={firstTab}>
        <TabsList class="mb-8 flex w-full flex-wrap gap-2">
          {sections.map((section, i) => (
            <TabsTrigger value={`section-${i}`}>
              {section.title}
            </TabsTrigger>
          ))}
        </TabsList>

        {sections.map((section, i) => (
          <TabsContent value={`section-${i}`}>
            {section.intro && (
              <p class="text-muted-foreground mb-6 text-pretty leading-relaxed">
                {section.intro}
              </p>
            )}
            <Accordion type="single">
              {section.items.map((item, j) => (
                <AccordionItem value={`section-${i}-item-${j}`}>
                  <AccordionTrigger>{item.question}</AccordionTrigger>
                  <AccordionContent>
                    <p class="text-muted-foreground leading-relaxed whitespace-pre-line">
                      {item.answer}
                    </p>
                  </AccordionContent>
                </AccordionItem>
              ))}
            </Accordion>
          </TabsContent>
        ))}
      </Tabs>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<script>
  let legalController: AbortController | null = null;

  function activateTabFromHash() {
    const hash = window.location.hash.replace('#', '');
    if (!hash) return;

    const trigger = document.querySelector<HTMLButtonElement>(
      `[role="tab"][data-value="${CSS.escape(hash)}"]`
    );
    if (trigger) trigger.click();

    const target = document.getElementById(hash);
    if (target) target.scrollIntoView({ behavior: 'smooth' });
  }

  function initLegal() {
    legalController?.abort();
    legalController = new AbortController();
    window.addEventListener('hashchange', activateTabFromHash, { signal: legalController.signal });
    activateTabFromHash();
  }

  initLegal();
  document.addEventListener('astro:after-swap', initLegal);
  document.addEventListener('astro:before-swap', () => { legalController?.abort(); legalController = null; });
</script>
