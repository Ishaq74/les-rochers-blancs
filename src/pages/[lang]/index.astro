---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import AboutSection from '@/components/sections/AboutSection.astro';
import RoomsSection from '@/components/sections/RoomsSection.astro';
import RestaurantSection from '@/components/sections/RestaurantSection.astro';
import MenuSection from '@/components/sections/MenuSection.astro';
import OpeningsSection from '@/components/sections/OpeningsSection.astro';
import PartnersSection from '@/components/sections/PartnersSection.astro';
import AccessSection from '@/components/sections/AccessSection.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import Footer from '@/components/layout/Footer.astro';
import { t, LOCALES, type Locale } from '@/lib/i18n';

export const prerender = true;

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const title = `${t('hero.title', lang)} — Les Rochers Blancs`;
const description = t('hero.tagline', lang);
---

<BaseLayout title={title} description={description} lang={lang}>
  <Navbar lang={lang} />
  <main>
    <HeroSection lang={lang} />
    <OpeningsSection lang={lang} />
    <RoomsSection lang={lang} />
    <RestaurantSection lang={lang} />
    <MenuSection lang={lang} />
    <PartnersSection lang={lang} />
    <AccessSection lang={lang} />
    <ContactSection lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
