---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import RoomsSection from '@/components/sections/RoomsSection.astro';
import RestaurantSection from '@/components/sections/RestaurantSection.astro';
import MenuSection from '@/components/sections/MenuSection.astro';
import OpeningsSection from '@/components/sections/OpeningsSection.astro';
import PartnersSection from '@/components/sections/PartnersSection.astro';
import AccessSection from '@/components/sections/AccessSection.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import Footer from '@/components/layout/Footer.astro';
import type { Locale } from '@/lib/i18n';
import { cms, getSetting, getPageSections } from '@/lib/settings';

// Must stay dynamic so admin DB updates are visible immediately on the public site.
export const prerender = false;

const { lang } = Astro.params as { lang: Locale };

const [heroTitle, brandName, tagline, address, phone, email] = await Promise.all([
  cms('hero', 'title', lang, 'hero.title'),
  getSetting('brand_name', 'footer.brandName', lang),
  cms('hero', 'tagline', lang, 'hero.tagline'),
  getSetting('address', 'contact.addressValue', lang),
  getSetting('phone', 'contact.phoneValue', lang),
  getSetting('email', 'contact.emailValue', lang),
]);

const title = `${heroTitle} — ${brandName}`;
const description = tagline;

const siteUrl = (import.meta.env.SITE_URL || 'https://lesrochersblancs.fr').replace(/\/$/, '');

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: brandName,
    url: `${siteUrl}/${lang}/`,
    inLanguage: lang,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Hotel',
    name: brandName,
    url: `${siteUrl}/${lang}/`,
    description,
    address: {
      '@type': 'PostalAddress',
      streetAddress: address,
      addressLocality: 'Bourg-Saint-Maurice',
      addressRegion: 'Savoie',
      postalCode: '73700',
      addressCountry: 'FR',
    },
    telephone: phone,
    email: email,
    hasMap: 'https://maps.google.com/?q=Les+Rochers+Blancs+Bourg-Saint-Maurice',
  },
];

const sectionLayout = await getPageSections();
const visibleSet = new Set(sectionLayout.filter(s => s.isVisible).map(s => s.sectionKey));

const sectionComponents: Record<string, any> = {
  hero: HeroSection,
  openings: OpeningsSection,
  rooms: RoomsSection,
  restaurant: RestaurantSection,
  menu: MenuSection,
  partners: PartnersSection,
  access: AccessSection,
  contact: ContactSection,
};
---

<BaseLayout title={title} description={description} lang={lang} jsonLd={jsonLd}>
  <Navbar lang={lang} />
  <main>
    {sectionLayout.map(({ sectionKey }) => {
      if (!visibleSet.has(sectionKey)) return null;
      const Component = sectionComponents[sectionKey];
      if (!Component) return null;
      return <Component lang={lang} />;
    })}
  </main>
  <Footer lang={lang} />
</BaseLayout>
