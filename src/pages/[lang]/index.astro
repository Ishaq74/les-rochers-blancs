---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/layout/Navbar.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import RoomsSection from '@/components/sections/RoomsSection.astro';
import RestaurantSection from '@/components/sections/RestaurantSection.astro';
import MenuSection from '@/components/sections/MenuSection.astro';
import OpeningsSection from '@/components/sections/OpeningsSection.astro';
import PartnersSection from '@/components/sections/PartnersSection.astro';
import AccessSection from '@/components/sections/AccessSection.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import Footer from '@/components/layout/Footer.astro';
import { t, LOCALES, type Locale } from '@/lib/i18n';

export const prerender = true;

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const title = `${t('hero.title', lang)} — ${t('footer.brandName', lang)}`;
const description = t('hero.tagline', lang);

const siteUrl = (import.meta.env.SITE_URL || 'https://lesrochersblancs.fr').replace(/\/$/, '');

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Les Rochers Blancs',
    url: `${siteUrl}/${lang}/`,
    inLanguage: lang,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Hotel',
    name: 'Les Rochers Blancs',
    url: `${siteUrl}/${lang}/`,
    description,
    address: {
      '@type': 'PostalAddress',
      streetAddress: t('contact.addressValue', lang),
      addressLocality: 'Bourg-Saint-Maurice',
      addressRegion: 'Savoie',
      postalCode: '73700',
      addressCountry: 'FR',
    },
    telephone: t('contact.phoneValue', lang),
    email: t('contact.emailValue', lang),
    hasMap: 'https://maps.google.com/?q=Les+Rochers+Blancs+Bourg-Saint-Maurice',
  },
];
---

<BaseLayout title={title} description={description} lang={lang} jsonLd={jsonLd}>
  <Navbar lang={lang} />
  <main>
    <HeroSection lang={lang} />
    <OpeningsSection lang={lang} />
    <RoomsSection lang={lang} />
    <RestaurantSection lang={lang} />
    <MenuSection lang={lang} />
    <PartnersSection lang={lang} />
    <AccessSection lang={lang} />
    <ContactSection lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
