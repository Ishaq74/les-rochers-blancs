---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { t } from '@/lib/i18n';
export const prerender = false;
const lang = 'fr';
const i18n = {
  all: t('common.all', lang),
  edit: t('common.edit', lang),
  delete: t('common.delete', lang),
  results: t('common.results', lang),
  previous: t('common.previous', lang),
  next: t('common.next', lang),
  newTitle: t('reservations.newTitle', lang),
  editTitle: t('reservations.editTitle', lang),
  confirmDelete: t('reservations.confirmDelete', lang),
  statusPending: t('reservations.status.pending', lang),
  statusConfirmed: t('reservations.status.confirmed', lang),
  statusCancelled: t('reservations.status.cancelled', lang),
  statusCompleted: t('reservations.status.completed', lang),
  typeRoom: t('reservations.type.room', lang),
  typeRestaurant: t('reservations.type.restaurant', lang),
  typeService: t('reservations.type.service', lang),
};
---

<AdminLayout title={t('reservations.title', lang)} activeNav="reservations" lang={lang}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold tracking-tight">{t('reservations.title', lang)}</h1>
        <p class="text-muted-foreground">{t('reservations.subtitle', lang)}</p>
      </div>
      <button id="btn-add" type="button" class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">+ {t('reservations.new', lang)}</button>
    </div>

    <!-- Status filter -->
    <div class="flex gap-2">
      {['all', 'pending', 'confirmed', 'cancelled', 'completed'].map(s => (
        <button data-filter={s} class:list={['rounded-full px-3 py-1 text-xs font-medium border transition-colors', s === 'all' ? 'border-primary bg-primary/10 text-primary' : 'border-border text-muted-foreground hover:bg-muted']}>
          {s === 'all' ? t('common.all', lang) : t(`reservations.status.${s}`, lang)}
        </button>
      ))}
    </div>

    <div class="rounded-xl border border-border bg-card shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="border-b border-border bg-muted/50">
          <tr>
            <th class="px-4 py-3 text-left font-medium">{t('reservations.table.type', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('reservations.table.dates', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('reservations.table.guests', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('reservations.table.amount', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('reservations.table.status', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('common.actions', lang)}</th>
          </tr>
        </thead>
        <tbody id="data-tbody"></tbody>
      </table>
      <p id="data-empty" class="hidden p-8 text-center text-muted-foreground">{t('reservations.noItems', lang)}</p>
    </div>
    <div id="pagination" class="flex items-center justify-between text-sm text-muted-foreground"></div>
  </div>

  <div id="edit-dialog" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50" data-close></div>
    <div class="fixed inset-y-0 right-0 w-full max-w-md overflow-y-auto bg-card border-l border-border shadow-xl p-6 space-y-4">
      <h2 id="dialog-title" class="text-lg font-semibold">{t('reservations.newTitle', lang)}</h2>
      <form id="edit-form" class="space-y-4">
        <input type="hidden" name="id" />
        <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.type', lang)} *</label>
          <select name="type" required class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm">
            <option value="room">{t('reservations.type.room', lang)}</option><option value="restaurant">{t('reservations.type.restaurant', lang)}</option><option value="service">{t('reservations.type.service', lang)}</option>
          </select>
        </div>
        <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.status', lang)}</label>
          <select name="status" class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm">
            <option value="pending">{t('reservations.status.pending', lang)}</option><option value="confirmed">{t('reservations.status.confirmed', lang)}</option>
            <option value="cancelled">{t('reservations.status.cancelled', lang)}</option><option value="completed">{t('reservations.status.completed', lang)}</option>
          </select>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.startDate', lang)}</label><input name="startDate" type="datetime-local" required class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
          <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.endDate', lang)}</label><input name="endDate" type="datetime-local" class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.guests', lang)}</label><input name="guestsCount" type="number" min="1" value="1" class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
          <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.amount', lang)}</label><input name="totalAmount" class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
        </div>
        <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.specialRequests', lang)}</label><textarea name="specialRequests" rows="2" class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm"></textarea></div>
        <div class="space-y-1"><label class="text-sm font-medium">{t('reservations.form.notes', lang)}</label><textarea name="notes" rows="2" class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm"></textarea></div>
        <div class="flex gap-2 pt-2">
          <button type="submit" class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">{t('common.save', lang)}</button>
          <button type="button" data-close class="inline-flex items-center rounded-md border border-input px-4 py-2 text-sm font-medium hover:bg-muted">{t('common.cancel', lang)}</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline define:vars={{ i18n }}>
    const API = (a,b) => fetch(`/_actions/${a}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(r=>r.json());
    function openD(){document.getElementById('edit-dialog')?.classList.remove('hidden')} function closeD(){document.getElementById('edit-dialog')?.classList.add('hidden')}
    document.querySelectorAll('[data-close]').forEach(el=>el.addEventListener('click',closeD));

    const statusColors = { pending:'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400', confirmed:'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400', cancelled:'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400', completed:'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' };
    const statusLabels = { pending:i18n.statusPending, confirmed:i18n.statusConfirmed, cancelled:i18n.statusCancelled, completed:i18n.statusCompleted };
    const typeLabels = { room:i18n.typeRoom, restaurant:i18n.typeRestaurant, service:i18n.typeService };

    let currentFilter = 'all', currentPage = 1;
    document.querySelectorAll('[data-filter]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-filter]').forEach(b => { b.classList.remove('border-primary','bg-primary/10','text-primary'); b.classList.add('border-border','text-muted-foreground'); });
        btn.classList.add('border-primary','bg-primary/10','text-primary'); btn.classList.remove('border-border','text-muted-foreground');
        currentFilter = btn.dataset.filter; currentPage = 1; load();
      });
    });

    let result = { items:[], total:0, totalPages:0 };
    async function load() {
      const params = { page: currentPage, limit: 20 };
      if (currentFilter !== 'all') params.status = currentFilter;
      const r = await API('listReservations', params);
      result = r.data ?? r; render();
    }
    function fmtDate(d) { return d ? new Date(d).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', year:'numeric' }) : '—'; }
    function render() {
      const tbody = document.getElementById('data-tbody'), empty = document.getElementById('data-empty');
      const items = result.items || [];
      if (!items.length) { tbody.innerHTML=''; empty.classList.remove('hidden'); return; }
      empty.classList.add('hidden');
      tbody.innerHTML = items.map(r => `<tr class="border-b border-border hover:bg-muted/50">
        <td class="px-4 py-3 font-medium">${escapeHtml(typeLabels[r.type]||r.type)}</td>
        <td class="px-4 py-3">${fmtDate(r.startDate)}${r.endDate ? ' → '+fmtDate(r.endDate) : ''}</td>
        <td class="px-4 py-3">${escapeHtml(String(r.guestsCount))}</td>
        <td class="px-4 py-3">${r.totalAmount ? escapeHtml(r.totalAmount)+' €' : '—'}</td>
        <td class="px-4 py-3"><span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[r.status]||""}">${escapeHtml(statusLabels[r.status]||r.status)}</span></td>
        <td class="px-4 py-3 space-x-2">
          <button onclick="edit('${escapeHtml(r.id)}')" class="text-xs text-primary hover:underline">${i18n.edit}</button>
          <button onclick="del('${escapeHtml(r.id)}')" class="text-xs text-destructive hover:underline">${i18n.delete}</button>
        </td></tr>`).join('');
      document.getElementById('pagination').innerHTML = `<span>${result.total||0} ${i18n.results}</span><div class="flex gap-2">${currentPage>1?`<button onclick="goPage(${currentPage-1})" class="text-xs text-primary hover:underline">← ${i18n.previous}</button>`:''}${(result.totalPages||0)>currentPage?`<button onclick="goPage(${currentPage+1})" class="text-xs text-primary hover:underline">${i18n.next} →</button>`:''}</div>`;
    }
    window.goPage = function(p) { currentPage=p; load(); };

    document.getElementById('btn-add')?.addEventListener('click', () => {
      const f = document.getElementById('edit-form'); f.reset(); f.querySelector('[name=id]').value='';
      document.getElementById('dialog-title').textContent = i18n.newTitle; openD();
    });
    window.edit = function(id) {
      const items = result.items||[]; const r = items.find(x=>x.id===id); if(!r) return;
      const f = document.getElementById('edit-form'); f.querySelector('[name=id]').value=r.id;
      f.type.value=r.type; f.status.value=r.status;
      f.startDate.value = r.startDate ? new Date(r.startDate).toISOString().slice(0,16) : '';
      f.endDate.value = r.endDate ? new Date(r.endDate).toISOString().slice(0,16) : '';
      f.guestsCount.value=r.guestsCount||1; f.totalAmount.value=r.totalAmount||'';
      f.specialRequests.value=r.specialRequests||''; f.notes.value=r.notes||'';
      document.getElementById('dialog-title').textContent=i18n.editTitle; openD();
    };
    document.getElementById('edit-form')?.addEventListener('submit', async e => {
      e.preventDefault(); const f=e.target; const id=f.querySelector('[name=id]').value||undefined;
      const startDate = f.startDate.value ? new Date(f.startDate.value).toISOString() : undefined;
      const endDate = f.endDate.value ? new Date(f.endDate.value).toISOString() : null;
      await API('saveReservation', { id, type:f.type.value, status:f.status.value, startDate, endDate, guestsCount:parseInt(f.guestsCount.value)||1, totalAmount:f.totalAmount.value||null, specialRequests:f.specialRequests.value||undefined, notes:f.notes.value||undefined });
      closeD(); load();
    });
    window.del = async id => { if(!confirm(i18n.confirmDelete)) return; await API('deleteReservation',{id}); load(); };
    load();
  </script>
</AdminLayout>
