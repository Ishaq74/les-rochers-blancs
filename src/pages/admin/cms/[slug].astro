---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { LOCALES } from '@/lib/i18n';
export const prerender = false;
const lang = 'fr';
const locales = LOCALES;
const { slug } = Astro.params;
---

<AdminLayout title="Éditeur de page" activeNav="pages" lang={lang}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3 min-w-0">
        <a href="/admin/cms" class="rounded-md p-1.5 hover:bg-muted transition-colors shrink-0" title="Retour">
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <div class="min-w-0">
          <h1 id="page-title" class="text-2xl font-bold tracking-tight truncate">Chargement…</h1>
          <p class="text-muted-foreground text-sm">Organisez les sections, éditez vos contenus markdown et prévisualisez en direct.</p>
        </div>
      </div>
      <div class="flex items-center gap-3 self-start sm:self-auto">
        <div id="dirty-indicator" class="hidden items-center gap-1 rounded-full border border-amber-300 bg-amber-100 px-2 py-1 text-[11px] font-medium text-amber-800">
          <span class="inline-flex size-1.5 rounded-full bg-amber-600"></span>
          Modifications non sauvegardees
        </div>
        <button id="btn-save" type="button" class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 disabled:opacity-50 shrink-0">
          <svg id="save-icon" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
          <svg id="save-spinner" class="size-4 animate-spin hidden" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          <span id="save-label">Sauvegarder tout</span>
        </button>
      </div>
    </div>

    <!-- Sections list (DnD + collapsible content editors) -->
    <div id="sections-container" class="space-y-2">
      <div class="flex items-center justify-center py-12">
        <svg class="size-5 animate-spin text-muted-foreground" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.25"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <span class="ml-2 text-sm text-muted-foreground">Chargement des sections…</span>
      </div>
    </div>

    <!-- Empty sections state -->
    <div id="empty-sections" class="hidden">
      <div class="flex flex-col items-center justify-center py-12 text-center rounded-lg border border-dashed border-border">
        <svg class="size-10 text-muted-foreground/40 mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="4" rx="1"/><rect x="3" y="10" width="18" height="4" rx="1"/><rect x="3" y="17" width="18" height="4" rx="1"/></svg>
        <p class="text-sm font-medium text-muted-foreground">Aucune section</p>
        <p class="text-xs text-muted-foreground/70 mt-1">Ajoutez une section pour commencer.</p>
      </div>
    </div>

    <!-- Add section -->
    <div>
      <div class="grid gap-2 md:grid-cols-[200px_1fr_1fr_auto]">
        <select id="preset-section" class="flex h-9 rounded-md border border-input bg-background px-3 text-sm">
          <option value="">Preset section</option>
          <option value="hero">hero</option>
          <option value="openings">openings</option>
          <option value="rooms">rooms</option>
          <option value="restaurant">restaurant</option>
          <option value="menu">menu</option>
          <option value="partners">partners</option>
          <option value="access">access</option>
          <option value="contact">contact</option>
        </select>
        <input id="new-section-key" placeholder="Cle de section (ex: intro, team, faq)" class="flex h-9 rounded-md border border-input bg-background px-3 text-sm font-mono" />
        <input id="new-section-label" placeholder="Libelle affiche" class="flex h-9 rounded-md border border-input bg-background px-3 text-sm" />
        <button id="btn-add-section" type="button" class="inline-flex items-center justify-center gap-1 rounded-md border border-input px-3 py-2 text-sm font-medium hover:bg-muted shrink-0">
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
          Section
        </button>
      </div>
      <p class="mt-2 text-xs text-muted-foreground">Astuce: utilisez un preset pour eviter les erreurs de cle, puis personnalisez le libelle.</p>
    </div>
  </div>

  <!-- Media picker dialog -->
  <div id="media-dialog" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" data-close-media></div>
    <div class="fixed inset-0 flex items-center justify-center p-4">
      <div class="bg-card rounded-xl border border-border shadow-2xl p-6 space-y-4 w-full max-w-4xl max-h-[85vh] overflow-hidden animate-in fade-in zoom-in-95">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold">Insérer une image</h3>
          <button type="button" data-close-media class="rounded-md p-1 hover:bg-muted text-muted-foreground hover:text-foreground transition-colors">
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <div id="media-picker-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 overflow-y-auto max-h-[65vh]"></div>
      </div>
    </div>
  </div>

  <!-- New field dialog -->
  <div id="field-dialog" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" data-close-field></div>
    <div class="fixed inset-0 flex items-center justify-center p-4">
      <div class="bg-card rounded-xl border border-border shadow-2xl p-6 space-y-4 w-full max-w-sm animate-in fade-in zoom-in-95">
        <div class="flex items-center justify-between">
          <h3 class="text-lg font-semibold">Nouveau champ</h3>
          <button type="button" data-close-field class="rounded-md p-1 hover:bg-muted text-muted-foreground hover:text-foreground transition-colors">
            <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <div class="space-y-1.5">
          <label for="new-field-key" class="text-sm font-medium">Clé du champ</label>
          <input id="new-field-key" placeholder="ex: title, description, buttonText…" class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm font-mono focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" />
        </div>
        <div class="flex gap-2">
          <button id="btn-create-field" type="button" class="inline-flex flex-1 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">Créer le champ</button>
          <button type="button" data-close-field class="inline-flex items-center rounded-md border border-input px-4 py-2 text-sm font-medium hover:bg-muted">Annuler</button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ slug, locales }}>
    async function API(action, body) {
      var res = await fetch('/_actions/' + action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      return res.json();
    }

    let sections = [];
    let allContent = [];
    let activeLocales = {};
    let draggedIdx = null;
    let mediaItems = [];
    let activeTextarea = null;
    let fieldTargetSection = '';
    let dirtyMap = new Map();

    const KNOWN_LABELS = {
      hero: 'Hero (En-tete)',
      openings: 'Ouvertures',
      rooms: 'Hotel / Chambres',
      restaurant: 'Restaurant',
      menu: 'Menus',
      partners: 'Partenaires',
      access: 'Acces / Carte',
      contact: 'Contact',
    };

    const DEFAULT_HOMEPAGE_SECTIONS = ['hero', 'openings', 'rooms', 'restaurant', 'menu', 'partners', 'access', 'contact'];
    const SECTION_CONTENT_KEY = { rooms: 'hotel' };

    function resolveContentSectionKey(sectionKey) {
      return SECTION_CONTENT_KEY[sectionKey] || sectionKey;
    }

    function normalizeKey(value) {
      return String(value || '').trim().toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
    }

    function getDraftStorageKey(sectionKey, fieldKey, locale) {
      return 'cms:draft:' + slug + ':' + sectionKey + ':' + fieldKey + ':' + locale;
    }

    function setDirtyIndicator() {
      var hasDirty = dirtyMap.size > 0;
      var indicator = document.getElementById('dirty-indicator');
      if (indicator) {
        indicator.classList.toggle('hidden', !hasDirty);
        indicator.classList.toggle('inline-flex', hasDirty);
      }
    }

    function setFieldDirty(sectionKey, fieldKey, locale, isDirty) {
      var key = sectionKey + '|' + fieldKey + '|' + locale;
      if (isDirty) dirtyMap.set(key, true);
      else dirtyMap.delete(key);
      setDirtyIndicator();
    }

    function getCmsRow(sectionKey, fieldKey, locale) {
      return allContent.find(function(c) {
        return c.sectionKey === sectionKey && c.fieldKey === fieldKey && c.locale === locale;
      });
    }

    function getFieldValue(sectionKey, fieldKey, locale) {
      var row = getCmsRow(sectionKey, fieldKey, locale);
      var base = row ? row.content : '';
      var draft = localStorage.getItem(getDraftStorageKey(sectionKey, fieldKey, locale));
      if (draft !== null && draft !== base) {
        setFieldDirty(sectionKey, fieldKey, locale, true);
        return draft;
      }
      return base;
    }

    function markdownToHtml(md) {
      var h = escapeHtml(md || '');
      h = h.replace(/^```([a-z0-9_-]*)\n([\s\S]*?)```/gim, function(_, lang, code) {
        var badge = lang ? '<div class="text-[11px] text-muted-foreground mb-1">' + lang + '</div>' : '';
        return '<div class="rounded-md bg-muted p-3 my-2 overflow-x-auto">' + badge + '<pre><code>' + code + '</code></pre></div>';
      });
      h = h.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
      h = h.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
      h = h.replace(/^#\s+(.+)$/gm, '<h1>$1</h1>');
      h = h.replace(/^>\s+(.+)$/gm, '<blockquote class="border-l-2 border-primary/30 pl-3 italic text-muted-foreground">$1</blockquote>');
      h = h.replace(/^---$/gm, '<hr />');
      h = h.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
      h = h.replace(/~~(.+?)~~/g, '<del>$1</del>');
      h = h.replace(/\*(.+?)\*/g, '<em>$1</em>');
      h = h.replace(/`([^`]+)`/g, '<code class="rounded bg-muted px-1 py-0.5 text-xs">$1</code>');
      h = h.replace(/!\[(.*?)\]\((.*?)\)/g, '<img alt="$1" src="$2" class="max-w-full h-auto rounded-md my-2" />');
      h = h.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" class="text-primary underline" target="_blank" rel="noopener noreferrer">$1</a>');
      h = h.replace(/^(\s*)-\s+(.+)$/gm, '$1<li>$2</li>');
      h = h.replace(/^(\s*)\d+\.\s+(.+)$/gm, '$1<li>$2</li>');
      h = h.replace(/(<li>.*?<\/li>)/gs, '<ul class="list-disc pl-6">$1</ul>');
      h = h.replace(/<\/ul>\s*<ul class="list-disc pl-6">/g, '');
      h = h.replace(/\n{2,}/g, '</p><p>');
      h = h.replace(/\n/g, '<br />');
      if (h.trim()) h = '<p>' + h + '</p>';
      return h;
    }

    function insertAtCursor(textarea, text, selectOffset) {
      var start = textarea.selectionStart ?? textarea.value.length;
      var end = textarea.selectionEnd ?? textarea.value.length;
      textarea.value = textarea.value.slice(0, start) + text + textarea.value.slice(end);
      textarea.focus();
      var next = typeof selectOffset === 'number' ? start + selectOffset : start + text.length;
      textarea.setSelectionRange(next, next);
      textarea.dispatchEvent(new Event('input', { bubbles: true }));
    }

    function applyMarkdownAction(textarea, action) {
      if (!textarea) return;
      if (action === 'h1') return insertAtCursor(textarea, '# Titre\n');
      if (action === 'h2') return insertAtCursor(textarea, '## Titre\n');
      if (action === 'h3') return insertAtCursor(textarea, '### Titre\n');
      if (action === 'bold') return insertAtCursor(textarea, '**texte**', 2);
      if (action === 'italic') return insertAtCursor(textarea, '*texte*', 1);
      if (action === 'strike') return insertAtCursor(textarea, '~~texte~~', 2);
      if (action === 'quote') return insertAtCursor(textarea, '> citation\n');
      if (action === 'ul') return insertAtCursor(textarea, '- element\n');
      if (action === 'ol') return insertAtCursor(textarea, '1. element\n');
      if (action === 'code') return insertAtCursor(textarea, '```\ncode\n```', 4);
      if (action === 'link') return insertAtCursor(textarea, '[texte](https://)', 1);
      if (action === 'hr') return insertAtCursor(textarea, '\n---\n');
      if (action === 'image') return openMediaDialog(textarea);
    }

    async function loadMediaItems() {
      if (mediaItems.length > 0) return;
      var r = await API('listMedia', { page: 1, limit: 200 });
      var payload = r.data ?? r;
      mediaItems = payload.items ?? [];
    }

    function renderMediaPicker() {
      var grid = document.getElementById('media-picker-grid');
      if (!mediaItems.length) {
        grid.innerHTML = '<p class="text-sm text-muted-foreground col-span-full">Aucune image. Uploadez-en dans la mediatheque.</p>';
        return;
      }

      grid.innerHTML = mediaItems.map(function(m) {
        var isImage = (m.fileType || '').startsWith('image/');
        return '<button type="button" class="border border-border rounded-lg overflow-hidden text-left hover:border-primary" data-media-url="' + m.fileUrl + '" data-media-name="' + (m.originalFilename || '').replace(/"/g, '&quot;') + '">' +
          '<div class="aspect-square bg-muted flex items-center justify-center overflow-hidden">' +
            (isImage ? '<img src="' + m.fileUrl + '" alt="" class="w-full h-full object-cover" loading="lazy"/>' : '<span class="text-2xl">PDF</span>') +
          '</div>' +
          '<div class="p-2 text-xs truncate">' + (m.originalFilename || m.fileUrl) + '</div>' +
        '</button>';
      }).join('');

      grid.querySelectorAll('[data-media-url]').forEach(function(el) {
        el.addEventListener('click', function() {
          if (!activeTextarea) return;
          var url = el.getAttribute('data-media-url') || '';
          var name = el.getAttribute('data-media-name') || 'image';
          insertAtCursor(activeTextarea, '![' + name + '](' + url + ')');
          closeMediaDialog();
        });
      });
    }

    function openMediaDialog(textarea) {
      activeTextarea = textarea || activeTextarea;
      document.getElementById('media-dialog')?.classList.remove('hidden');
      loadMediaItems().then(renderMediaPicker);
    }

    function closeMediaDialog() {
      document.getElementById('media-dialog')?.classList.add('hidden');
    }

    function getFieldsForSection(sectionKey) {
      var cmsSection = resolveContentSectionKey(sectionKey);
      var keys = new Set();
      allContent.forEach(function(c) {
        if (c.sectionKey === cmsSection) keys.add(c.fieldKey);
      });
      return Array.from(keys).sort();
    }

    function updatePreview(textarea, previewEl) {
      if (!previewEl) return;
      previewEl.innerHTML = markdownToHtml(textarea.value);
    }

    function render() {
      var container = document.getElementById('sections-container');
      var emptyState = document.getElementById('empty-sections');
      container.innerHTML = '';

      if (!sections.length) {
        emptyState?.classList.remove('hidden');
        return;
      }
      emptyState?.classList.add('hidden');

      sections.forEach(function(s, i) {
        var row = document.createElement('div');
        row.className = 'rounded-lg border border-border bg-card overflow-hidden transition-all ' + (s.isVisible ? '' : 'opacity-60');
        row.draggable = true;
        row.dataset.idx = String(i);

        var currentLocale = activeLocales[s.sectionKey] || locales[0];
        var cmsSection = resolveContentSectionKey(s.sectionKey);
        var sectionFields = getFieldsForSection(s.sectionKey);

        var header = document.createElement('div');
        header.className = 'flex items-center gap-3 px-4 py-3 cursor-grab active:cursor-grabbing select-none';
        header.innerHTML =
          '<button type="button" class="text-muted-foreground hover:text-foreground shrink-0" title="Glisser">' +
            '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="5" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="19" r="1"/></svg>' +
          '</button>' +
          '<div class="flex-1 min-w-0">' +
            '<div class="flex items-center gap-2">' +
              '<span class="font-medium text-sm">' + escapeHtml(s.label) + '</span>' +
              '<span class="text-[10px] rounded-full bg-muted px-2 py-0.5">' + sectionFields.length + ' champ(s)</span>' +
            '</div>' +
            '<span class="text-xs text-muted-foreground font-mono">' + escapeHtml(s.sectionKey) + '</span>' +
          '</div>' +
          '<label class="relative inline-flex items-center cursor-pointer shrink-0" title="Visible">' +
            '<input type="checkbox" class="sr-only peer" ' + (s.isVisible ? 'checked' : '') + ' data-toggle="' + i + '" />' +
            '<div class="w-9 h-5 bg-muted rounded-full peer-checked:bg-primary transition-colors after:content-[\'\'] after:absolute after:top-0.5 after:start-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-transform peer-checked:after:translate-x-4"></div>' +
          '</label>' +
          '<button type="button" data-expand="' + i + '" class="rounded-md p-1 hover:bg-muted transition-colors shrink-0" title="' + (s.expanded ? 'Reduire' : 'Modifier le contenu') + '">' +
            '<svg class="size-4 transition-transform ' + (s.expanded ? 'rotate-180' : '') + '" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>' +
          '</button>' +
          '<button type="button" data-delete-section="' + i + '" class="rounded-md p-1 hover:bg-destructive/10 text-muted-foreground hover:text-destructive transition-colors shrink-0" title="Supprimer la section">' +
            '<svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>' +
          '</button>';
        row.appendChild(header);

        if (s.expanded) {
          var editor = document.createElement('div');
          editor.className = 'border-t border-border px-4 py-4 space-y-4 bg-muted/30';

          var tabsHtml = '<div class="flex gap-1 border-b border-border pb-2 mb-3">';
          locales.forEach(function(l) {
            var isActive = l === currentLocale;
            tabsHtml += '<button type="button" data-locale-tab="' + l + '" data-section="' + s.sectionKey + '" class="px-3 py-1.5 text-xs font-medium rounded-md ' +
              (isActive ? 'bg-primary text-primary-foreground' : 'text-muted-foreground hover:text-foreground hover:bg-muted') + '">' + l.toUpperCase() + '</button>';
          });
          tabsHtml += '</div>';

          var fieldsHtml = '';
          if (!sectionFields.length) {
            fieldsHtml = '<p class="text-sm text-muted-foreground">Aucun champ. Ajoutez-en un.</p>';
          } else {
            sectionFields.forEach(function(fk) {
              var val = getFieldValue(cmsSection, fk, currentLocale);
              var fieldKey = cmsSection + '.' + fk;
              fieldsHtml +=
                '<div class="space-y-2 rounded-lg border border-border bg-card p-3">' +
                  '<div class="flex items-center justify-between gap-3">' +
                    '<label class="text-sm font-medium font-mono truncate">' + escapeHtml(fk) + '</label>' +
                    '<button type="button" data-del-field="' + fk + '" data-del-section="' + cmsSection + '" class="text-xs text-destructive hover:underline">Supprimer</button>' +
                  '</div>' +
                  '<div class="flex flex-wrap items-center gap-1.5 text-xs">' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="h1" data-md-field="' + fieldKey + '">H1</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="h2" data-md-field="' + fieldKey + '">H2</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="h3" data-md-field="' + fieldKey + '">H3</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="bold" data-md-field="' + fieldKey + '">Gras</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="italic" data-md-field="' + fieldKey + '">Italique</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="strike" data-md-field="' + fieldKey + '">Barre</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="quote" data-md-field="' + fieldKey + '">Quote</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="ul" data-md-field="' + fieldKey + '">Liste</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="ol" data-md-field="' + fieldKey + '">1.</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="code" data-md-field="' + fieldKey + '">Code</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="link" data-md-field="' + fieldKey + '">Lien</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="image" data-md-field="' + fieldKey + '">Image</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted" data-md="hr" data-md-field="' + fieldKey + '">HR</button>' +
                    '<button type="button" class="rounded border border-input px-1.5 py-0.5 hover:bg-muted ml-auto md:hidden" data-preview-toggle="' + fieldKey + '">Preview</button>' +
                  '</div>' +
                  '<div class="grid gap-3 md:grid-cols-2">' +
                    '<textarea data-cms-section="' + cmsSection + '" data-cms-field="' + fk + '" data-cms-locale="' + currentLocale + '" rows="9" class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm font-mono resize-y" placeholder="Contenu markdown...">' + escapeHtml(val) + '</textarea>' +
                    '<div data-preview-for="' + fieldKey + '" class="rounded-md border border-dashed border-border bg-background px-3 py-2 prose prose-sm max-w-none overflow-x-auto"></div>' +
                  '</div>' +
                '</div>';
            });
          }

          editor.innerHTML = tabsHtml + '<div class="space-y-3">' + fieldsHtml + '</div>' +
            '<div class="flex items-center gap-3 pt-2">' +
              '<button type="button" data-add-field="' + cmsSection + '" class="text-sm text-primary hover:underline">+ Ajouter un champ</button>' +
              '<button type="button" data-open-media="' + s.sectionKey + '" class="text-sm text-primary hover:underline">Mediatheque</button>' +
            '</div>';
          row.appendChild(editor);
        }

        row.addEventListener('dragstart', function(e) {
          draggedIdx = i;
          e.dataTransfer.effectAllowed = 'move';
          row.classList.add('opacity-50');
        });
        row.addEventListener('dragend', function() {
          draggedIdx = null;
          row.classList.remove('opacity-50');
        });
        row.addEventListener('dragover', function(e) {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          row.classList.add('ring-2', 'ring-primary/50');
        });
        row.addEventListener('dragleave', function() {
          row.classList.remove('ring-2', 'ring-primary/50');
        });
        row.addEventListener('drop', function(e) {
          e.preventDefault();
          row.classList.remove('ring-2', 'ring-primary/50');
          if (draggedIdx === null || draggedIdx === i) return;
          var moved = sections.splice(draggedIdx, 1)[0];
          sections.splice(i, 0, moved);
          sections.forEach(function(item, idx) { item.sortOrder = idx; });
          render();
        });

        var toggle = row.querySelector('[data-toggle="' + i + '"]');
        if (toggle) {
          toggle.addEventListener('change', function() {
            sections[i].isVisible = toggle.checked;
            row.classList.toggle('opacity-60', !toggle.checked);
            setFieldDirty(resolveContentSectionKey(sections[i].sectionKey), '__visible__', currentLocale, true);
          });
        }

        var expandBtn = row.querySelector('[data-expand="' + i + '"]');
        if (expandBtn) {
          expandBtn.addEventListener('click', function() {
            sections[i].expanded = !sections[i].expanded;
            render();
          });
        }

        var deleteBtn = row.querySelector('[data-delete-section="' + i + '"]');
        if (deleteBtn) {
          deleteBtn.addEventListener('click', function() {
            if (!confirm('Supprimer la section "' + s.label + '" ?')) return;
            sections.splice(i, 1);
            sections.forEach(function(item, idx) { item.sortOrder = idx; });
            showToast('Section supprimee', 'success');
            setDirtyIndicator();
            render();
          });
        }

        row.querySelectorAll('[data-locale-tab]').forEach(function(tabBtn) {
          tabBtn.addEventListener('click', function() {
            activeLocales[tabBtn.dataset.section] = tabBtn.dataset.localeTab;
            render();
          });
        });

        row.querySelectorAll('[data-md]').forEach(function(mdBtn) {
          mdBtn.addEventListener('click', function() {
            var key = mdBtn.dataset.mdField || '';
            var idxSep = key.indexOf('.');
            var section = key.slice(0, idxSep);
            var field = key.slice(idxSep + 1);
            var textarea = row.querySelector('textarea[data-cms-section="' + section + '"][data-cms-field="' + field + '"]');
            applyMarkdownAction(textarea, mdBtn.dataset.md);
          });
        });

        row.querySelectorAll('[data-preview-toggle]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var key = btn.dataset.previewToggle;
            var preview = row.querySelector('[data-preview-for="' + key + '"]');
            if (!preview) return;
            preview.classList.toggle('hidden');
          });
        });

        var addFieldBtn = row.querySelector('[data-add-field]');
        if (addFieldBtn) {
          addFieldBtn.addEventListener('click', function() {
            fieldTargetSection = addFieldBtn.dataset.addField;
            document.getElementById('new-field-key').value = '';
            document.getElementById('field-dialog')?.classList.remove('hidden');
          });
        }

        var mediaBtn = row.querySelector('[data-open-media]');
        if (mediaBtn) {
          mediaBtn.addEventListener('click', function() {
            openMediaDialog(null);
          });
        }

        row.querySelectorAll('[data-del-field]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var fk = btn.dataset.delField;
            var sk = btn.dataset.delSection;
            if (!confirm('Supprimer le champ "' + fk + '" pour toutes les langues ?')) return;
            var items = allContent.filter(function(c) { return c.sectionKey === sk && c.fieldKey === fk; });
            Promise.all(items.map(function(item) { return API('deleteCmsContent', { id: item.id }); }))
              .then(function() {
                showToast('Champ "' + fk + '" supprime', 'success');
                return loadCmsContent();
              })
              .then(function() {
                render();
              })
              .catch(function() {
                showToast('Erreur lors de la suppression', 'error');
              });
          });
        });

        row.querySelectorAll('textarea[data-cms-section]').forEach(function(ta) {
          var preview = row.querySelector('[data-preview-for="' + ta.dataset.cmsSection + '.' + ta.dataset.cmsField + '"]');
          updatePreview(ta, preview);

          ta.addEventListener('focus', function() {
            activeTextarea = ta;
          });

          ta.addEventListener('input', function() {
            var storageKey = getDraftStorageKey(ta.dataset.cmsSection, ta.dataset.cmsField, ta.dataset.cmsLocale);
            var baseRow = getCmsRow(ta.dataset.cmsSection, ta.dataset.cmsField, ta.dataset.cmsLocale);
            var baseVal = baseRow ? baseRow.content : '';
            localStorage.setItem(storageKey, ta.value);
            setFieldDirty(ta.dataset.cmsSection, ta.dataset.cmsField, ta.dataset.cmsLocale, ta.value !== baseVal);
            updatePreview(ta, preview);
          });
        });

        container.appendChild(row);
      });
    }

    async function loadCmsContent() {
      var cmsRes = await API('listCmsContent', {});
      var cmsData = cmsRes?.data ?? cmsRes;
      allContent = Array.isArray(cmsData) ? cmsData : [];
    }

    async function saveAll() {
      var btn = document.getElementById('btn-save');
      var saveIcon = document.getElementById('save-icon');
      var saveSpinner = document.getElementById('save-spinner');
      var saveLabel = document.getElementById('save-label');
      btn.disabled = true;
      saveIcon?.classList.add('hidden');
      saveSpinner?.classList.remove('hidden');
      saveLabel.textContent = 'Sauvegarde...';

      try {
        var payload = sections.map(function(item) {
          return { sectionKey: item.sectionKey, sortOrder: item.sortOrder, isVisible: item.isVisible };
        });
        await API('savePageSections', { pageSlug: slug, sections: payload });

        var textareas = document.querySelectorAll('textarea[data-cms-section]');
        for (var t = 0; t < textareas.length; t++) {
          var ta = textareas[t];
          await API('upsertCmsContent', {
            sectionKey: ta.dataset.cmsSection,
            locale: ta.dataset.cmsLocale,
            fieldKey: ta.dataset.cmsField,
            content: ta.value,
          });
          localStorage.removeItem(getDraftStorageKey(ta.dataset.cmsSection, ta.dataset.cmsField, ta.dataset.cmsLocale));
        }

        dirtyMap.clear();
        setDirtyIndicator();
        showToast('Tout sauvegarde avec succes', 'success');
        await loadCmsContent();
        render();
      } catch (err) {
        showToast('Erreur : ' + (err?.message || 'Echec de la sauvegarde'), 'error');
      } finally {
        btn.disabled = false;
        saveIcon?.classList.remove('hidden');
        saveSpinner?.classList.add('hidden');
        saveLabel.textContent = 'Sauvegarder tout';
      }
    }

    async function loadPage() {
      try {
        var pagesRes = await API('listPages', {});
        var pages = Array.isArray(pagesRes?.data) ? pagesRes.data : (Array.isArray(pagesRes) ? pagesRes : []);
        var page = pages.find(function(p) { return p.slug === slug; });
        document.getElementById('page-title').textContent = page ? page.title : slug;

        var secRes = await API('listPageSections', { pageSlug: slug });
        var secData = Array.isArray(secRes?.data) ? secRes.data : (Array.isArray(secRes) ? secRes : []);

        if (secData.length > 0) {
          sections = secData.map(function(item, i) {
            return {
              sectionKey: item.sectionKey,
              label: KNOWN_LABELS[item.sectionKey] || item.sectionKey,
              sortOrder: item.sortOrder ?? i,
              isVisible: item.isVisible !== false,
              expanded: i === 0,
            };
          });
          sections.sort(function(a, b) { return a.sortOrder - b.sortOrder; });
        } else if (slug === 'accueil') {
          sections = DEFAULT_HOMEPAGE_SECTIONS.map(function(key, i) {
            return {
              sectionKey: key,
              label: KNOWN_LABELS[key] || key,
              sortOrder: i,
              isVisible: true,
              expanded: i === 0,
            };
          });
        } else {
          sections = [];
        }

        await loadCmsContent();
        setDirtyIndicator();
        render();
      } catch (err) {
        showToast('Erreur de chargement de la page', 'error');
      }
    }

    document.getElementById('btn-save')?.addEventListener('click', saveAll);

    document.getElementById('preset-section')?.addEventListener('change', function() {
      var key = normalizeKey(this.value);
      if (!key) return;
      var keyInput = document.getElementById('new-section-key');
      var labelInput = document.getElementById('new-section-label');
      keyInput.value = key;
      if (!labelInput.value) labelInput.value = KNOWN_LABELS[key] || key;
    });

    document.getElementById('btn-add-section')?.addEventListener('click', function() {
      var keyInput = document.getElementById('new-section-key');
      var labelInput = document.getElementById('new-section-label');
      var key = normalizeKey(keyInput?.value || '');
      var label = (labelInput?.value || '').trim() || key;

      if (!key) {
        showToast('Entrez une cle de section', 'warning');
        return;
      }
      if (sections.find(function(item) { return item.sectionKey === key; })) {
        showToast('Cette section existe deja', 'warning');
        return;
      }

      sections.push({
        sectionKey: key,
        label: label,
        sortOrder: sections.length,
        isVisible: true,
        expanded: true,
      });

      keyInput.value = '';
      labelInput.value = '';
      document.getElementById('preset-section').value = '';
      showToast('Section "' + label + '" ajoutee', 'success');
      render();
    });

    document.querySelectorAll('[data-close-field]').forEach(function(el) {
      el.addEventListener('click', function() {
        document.getElementById('field-dialog')?.classList.add('hidden');
      });
    });

    document.getElementById('btn-create-field')?.addEventListener('click', async function() {
      var fk = normalizeKey(document.getElementById('new-field-key')?.value || '');
      if (!fk || !fieldTargetSection) {
        showToast('Entrez une cle de champ', 'warning');
        return;
      }

      try {
        await API('upsertCmsContent', {
          sectionKey: fieldTargetSection,
          locale: locales[0],
          fieldKey: fk,
          content: '',
        });
        document.getElementById('field-dialog')?.classList.add('hidden');
        showToast('Champ "' + fk + '" cree', 'success');
        await loadCmsContent();
        render();
      } catch (err) {
        showToast('Erreur lors de la creation du champ', 'error');
      }
    });

    document.querySelectorAll('[data-close-media]').forEach(function(el) {
      el.addEventListener('click', closeMediaDialog);
    });

    window.addEventListener('beforeunload', function(e) {
      if (dirtyMap.size > 0) {
        e.preventDefault();
      }
    });

    window.addEventListener('keydown', function(e) {
      var isSave = (e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 's';
      if (!isSave) return;
      e.preventDefault();
      saveAll();
    });

    loadPage();
  </script>
</AdminLayout>
