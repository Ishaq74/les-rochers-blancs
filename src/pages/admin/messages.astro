---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { t } from '@/lib/i18n';
export const prerender = false;
const lang = 'fr';
const i18n = {
  all: t('messages.filterAll', lang),
  unread: t('messages.filterUnread', lang),
  detail: t('messages.detail', lang),
  close: t('common.close', lang),
  previous: t('common.previous', lang),
  next: t('common.next', lang),
  view: t('common.view', lang),
  delete: t('common.delete', lang),
  countSuffix: t('messages.countSuffix', lang),
  markRead: t('messages.markRead', lang),
  markUnread: t('messages.markUnread', lang),
  confirmDelete: t('messages.confirmDelete', lang),
  toastDeleted: t('messages.toast.deleted', lang),
  toastMarkedRead: t('messages.toast.markedRead', lang),
  toastMarkedUnread: t('messages.toast.markedUnread', lang),
};
---

<AdminLayout title={t('messages.title', lang)} activeNav="messages" lang={lang}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold tracking-tight">{t('messages.title', lang)}</h1>
        <p class="text-muted-foreground">{t('messages.subtitle', lang)}</p>
      </div>
    </div>

    <div class="flex gap-2" id="read-filters">
      <button data-unread="" class="rounded-full px-3 py-1 text-xs font-medium border border-input bg-primary text-primary-foreground">{t('messages.filterAll', lang)}</button>
      <button data-unread="true" class="rounded-full px-3 py-1 text-xs font-medium border border-input hover:bg-muted">{t('messages.filterUnread', lang)}</button>
    </div>

    <div class="rounded-xl border border-border bg-card shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="border-b border-border bg-muted/50">
          <tr>
            <th class="px-4 py-3 text-left font-medium w-6"></th>
            <th class="px-4 py-3 text-left font-medium">{t('messages.table.sender', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('messages.table.message', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('messages.table.language', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('messages.table.date', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('common.actions', lang)}</th>
          </tr>
        </thead>
        <tbody id="data-tbody"></tbody>
      </table>
      <p id="data-empty" class="hidden p-8 text-center text-muted-foreground">{t('messages.noItems', lang)}</p>
    </div>
    <div id="pagination" class="flex items-center justify-between text-sm text-muted-foreground"></div>
  </div>

  <!-- Message Detail Dialog -->
  <div id="detail-dialog" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50" data-close></div>
    <div class="fixed inset-y-0 right-0 w-full max-w-md overflow-y-auto bg-card border-l border-border shadow-xl p-6 space-y-4">
      <h2 class="text-lg font-semibold">{t('messages.detail', lang)}</h2>
      <div class="space-y-3">
        <div><span class="text-xs text-muted-foreground">{t('messages.form.name', lang)}</span><p id="det-name" class="font-medium"></p></div>
        <div><span class="text-xs text-muted-foreground">{t('messages.form.email', lang)}</span><p id="det-email" class="font-medium"></p></div>
        <div><span class="text-xs text-muted-foreground">{t('messages.form.language', lang)}</span><p id="det-locale"></p></div>
        <div><span class="text-xs text-muted-foreground">{t('messages.form.date', lang)}</span><p id="det-date"></p></div>
        <div><span class="text-xs text-muted-foreground">{t('messages.form.message', lang)}</span><p id="det-message" class="whitespace-pre-wrap bg-muted/50 rounded-md p-3 text-sm max-h-60 overflow-y-auto"></p></div>
      </div>
      <div class="flex gap-2 pt-2">
        <button type="button" data-close class="inline-flex items-center rounded-md border border-input px-4 py-2 text-sm font-medium hover:bg-muted">{t('common.close', lang)}</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ i18n }}>
    const API=(a,b)=>fetch(`/_actions/${a}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(r=>r.json());
    function openD(){document.getElementById('detail-dialog')?.classList.remove('hidden')}function closeD(){document.getElementById('detail-dialog')?.classList.add('hidden')}
    document.querySelectorAll('[data-close]').forEach(el=>el.addEventListener('click',closeD));

    let currentPage=1,unreadOnly=false;
    let result={items:[],total:0,totalPages:0};

    document.querySelectorAll('#read-filters button').forEach(btn=>{
      btn.addEventListener('click',()=>{
        document.querySelectorAll('#read-filters button').forEach(b=>{b.classList.remove('bg-primary','text-primary-foreground');b.classList.add('hover:bg-muted')});
        btn.classList.add('bg-primary','text-primary-foreground');btn.classList.remove('hover:bg-muted');
        unreadOnly=btn.dataset.unread==='true';currentPage=1;load();
      });
    });

    async function load(){
      const r=await API('listContactMessages',{page:currentPage,limit:20,unreadOnly});
      result=r.data??r;render();
    }

    function render(){
      const tbody=document.getElementById('data-tbody'),empty=document.getElementById('data-empty');
      const items=result.items||[];
      if(!items.length){tbody.innerHTML='';empty.classList.remove('hidden');document.getElementById('pagination').innerHTML='';return;}
      empty.classList.add('hidden');
      tbody.innerHTML=items.map(r=>{
        const d=r.createdAt?new Date(r.createdAt).toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}):'';
        const bold=!r.isRead?'font-semibold':'';
        const messagePreview = r.message.length > 80 ? `${r.message.substring(0,80)}…` : r.message;
        return `<tr class="border-b border-border hover:bg-muted/50 ${bold}">
        <td class="px-4 py-3">${!r.isRead?'<span class="inline-block w-2 h-2 rounded-full bg-primary"></span>':''}</td>
        <td class="px-4 py-3"><div>${escapeHtml(r.name)}</div><div class="text-xs text-muted-foreground">${escapeHtml(r.email)}</div></td>
        <td class="px-4 py-3 max-w-xs truncate">${escapeHtml(messagePreview)}</td>
        <td class="px-4 py-3"><span class="inline-flex rounded-full bg-muted px-2 py-0.5 text-xs">${escapeHtml(r.locale||'fr')}</span></td>
        <td class="px-4 py-3 text-xs">${d}</td>
        <td class="px-4 py-3 space-x-2">
          <button onclick="view('${r.id}')" class="text-xs text-primary hover:underline">${i18n.view}</button>
          <button onclick="toggleRead('${r.id}',${r.isRead})" class="text-xs ${r.isRead?'text-yellow-600':'text-green-600'} hover:underline">${r.isRead?i18n.markUnread:i18n.markRead}</button>
          <button onclick="del('${r.id}')" class="text-xs text-destructive hover:underline">${i18n.delete}</button>
        </td></tr>`;
      }).join('');
      document.getElementById('pagination').innerHTML=`<span>${result.total||0} ${i18n.countSuffix}</span><div class="flex gap-2">${currentPage>1?`<button onclick="goPage(${currentPage-1})" class="text-xs text-primary hover:underline">← ${i18n.previous}</button>`:''}${(result.totalPages||0)>currentPage?`<button onclick="goPage(${currentPage+1})" class="text-xs text-primary hover:underline">${i18n.next} →</button>`:''}</div>`;
    }
    window.goPage=p=>{currentPage=p;load()};

    window.view=async function(id){
      const r=(result.items||[]).find(x=>x.id===id);if(!r)return;
      document.getElementById('det-name').textContent=r.name;
      document.getElementById('det-email').textContent=r.email;
      document.getElementById('det-locale').textContent=r.locale||'fr';
      document.getElementById('det-date').textContent=r.createdAt?new Date(r.createdAt).toLocaleDateString('fr-FR',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}):'';
      document.getElementById('det-message').textContent=r.message;
      if(!r.isRead){await API('markMessageRead',{id,isRead:true});r.isRead=true;render();}
      openD();
    };

    window.toggleRead=async function(id,isRead){
      await API('markMessageRead',{id,isRead:!isRead});
      showToast(!isRead ? i18n.toastMarkedRead : i18n.toastMarkedUnread, 'success');
      load();
    };
    window.del=async id=>{if(!confirm(i18n.confirmDelete))return;await API('deleteContactMessage',{id});showToast(i18n.toastDeleted,'success');load()};
    load();
  </script>
</AdminLayout>
