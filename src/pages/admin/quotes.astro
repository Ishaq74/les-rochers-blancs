---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { t } from '@/lib/i18n';
export const prerender = false;
const lang = 'fr';
const i18n = {
  all: t('common.all', lang),
  edit: t('common.edit', lang),
  delete: t('common.delete', lang),
  previous: t('common.previous', lang),
  next: t('common.next', lang),
  notes: t('common.notes', lang),
  status: t('common.status', lang),
  newTitle: t('quotes.newTitle', lang),
  editTitle: t('quotes.editTitle', lang),
  confirmDelete: t('quotes.confirmDelete', lang),
  countSuffix: t('quotes.countSuffix', lang),
  statusDraft: t('quotes.status.draft', lang),
  statusSent: t('quotes.status.sent', lang),
  statusAccepted: t('quotes.status.accepted', lang),
  statusRejected: t('quotes.status.rejected', lang),
  statusExpired: t('quotes.status.expired', lang),
  statusConverted: t('quotes.status.converted', lang),
  convertTitle: t('quotes.convert.title', lang),
  convertInvoiceNumber: t('quotes.convert.invoiceNumber', lang),
  convertDueDate: t('quotes.convert.dueDate', lang),
  convertSubmit: t('quotes.convert.submit', lang),
  convertToInvoice: t('quotes.convert.toInvoice', lang),
  tableNumber: t('quotes.table.number', lang),
  tableClient: t('quotes.table.client', lang),
  tableDate: t('quotes.table.date', lang),
  tableValidity: t('quotes.table.validity', lang),
  tableTotal: t('quotes.table.total', lang),
  formNumber: t('quotes.form.number', lang),
  formClient: t('quotes.form.client', lang),
  formClientPlaceholder: t('quotes.form.clientPlaceholder', lang),
  formStatus: t('quotes.form.status', lang),
  formIssueDate: t('quotes.form.issueDate', lang),
  formValidUntil: t('quotes.form.validUntil', lang),
  formTaxRate: t('quotes.form.taxRate', lang),
  formLines: t('quotes.form.lines', lang),
  formAddLine: t('quotes.form.addLine', lang),
  formDescPlaceholder: t('quotes.form.descriptionPlaceholder', lang),
  formQtyPlaceholder: t('quotes.form.qtyPlaceholder', lang),
  formPricePlaceholder: t('quotes.form.pricePlaceholder', lang),
  formSubtotal: t('quotes.form.subtotal', lang),
  formTax: t('quotes.form.tax', lang),
  formTotalTtc: t('quotes.form.totalTTC', lang),
};
const taxLabel = t('quotes.form.tax', lang).replace('{{rate}}', '20');
---

<AdminLayout title={t('quotes.title', lang)} activeNav="quotes" lang={lang}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold tracking-tight">{t('quotes.title', lang)}</h1>
        <p class="text-muted-foreground">{t('quotes.subtitle', lang)}</p>
      </div>
      <button id="btn-add" type="button" class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">+ {t('quotes.new', lang)}</button>
    </div>

    <div class="flex gap-2 flex-wrap" id="status-filters">
      <button data-status="" class="rounded-full px-3 py-1 text-xs font-medium border border-input bg-primary text-primary-foreground">{t('common.all', lang)}</button>
      <button data-status="draft" class="rounded-full px-3 py-1 text-xs font-medium border border-input hover:bg-muted">{t('quotes.status.draft', lang)}</button>
      <button data-status="sent" class="rounded-full px-3 py-1 text-xs font-medium border border-input hover:bg-muted">{t('quotes.status.sent', lang)}</button>
      <button data-status="accepted" class="rounded-full px-3 py-1 text-xs font-medium border border-input hover:bg-muted">{t('quotes.status.accepted', lang)}</button>
      <button data-status="rejected" class="rounded-full px-3 py-1 text-xs font-medium border border-input hover:bg-muted">{t('quotes.status.rejected', lang)}</button>
      <button data-status="expired" class="rounded-full px-3 py-1 text-xs font-medium border border-input hover:bg-muted">{t('quotes.status.expired', lang)}</button>
      <button data-status="converted" class="rounded-full px-3 py-1 text-xs font-medium border border-input hover:bg-muted">{t('quotes.status.converted', lang)}</button>
    </div>

    <div class="rounded-xl border border-border bg-card shadow-sm overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="border-b border-border bg-muted/50">
          <tr>
            <th class="px-4 py-3 text-left font-medium">{t('quotes.table.number', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('quotes.table.client', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('common.status', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('quotes.table.date', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('quotes.table.validity', lang)}</th>
            <th class="px-4 py-3 text-right font-medium">{t('quotes.table.total', lang)}</th>
            <th class="px-4 py-3 text-left font-medium">{t('common.actions', lang)}</th>
          </tr>
        </thead>
        <tbody id="data-tbody"></tbody>
      </table>
      <p id="data-empty" class="hidden p-8 text-center text-muted-foreground">{t('quotes.noItems', lang)}</p>
    </div>
    <div id="pagination" class="flex items-center justify-between text-sm text-muted-foreground"></div>
  </div>

  <!-- Convert to Invoice Dialog -->
  <div id="convert-dialog" class="fixed inset-0 z-60 hidden">
    <div class="fixed inset-0 bg-black/50" data-close-convert></div>
    <div class="fixed inset-0 flex items-center justify-center p-4">
      <div class="bg-card rounded-xl border border-border shadow-xl p-6 space-y-4 w-full max-w-sm">
        <h3 class="text-lg font-semibold">{t('quotes.convert.title', lang)}</h3>
        <form id="convert-form" class="space-y-4">
          <input type="hidden" name="quoteId" />
          <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.convert.invoiceNumber', lang)}</label><input name="invoiceNumber" required class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
          <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.convert.dueDate', lang)}</label><input name="dueDate" type="date" required class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
          <div class="flex gap-2">
            <button type="submit" class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">{t('quotes.convert.submit', lang)}</button>
            <button type="button" data-close-convert class="inline-flex items-center rounded-md border border-input px-4 py-2 text-sm font-medium hover:bg-muted">Annuler</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Quote Edit Dialog -->
  <div id="edit-dialog" class="fixed inset-0 z-50 hidden">
    <div class="fixed inset-0 bg-black/50" data-close></div>
    <div class="fixed inset-y-0 right-0 w-full max-w-lg overflow-y-auto bg-card border-l border-border shadow-xl p-6 space-y-4">
      <h2 id="dialog-title" class="text-lg font-semibold">{t('quotes.newTitle', lang)}</h2>
      <form id="edit-form" class="space-y-4">
        <input type="hidden" name="id" />
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.form.number', lang)}</label><input name="quoteNumber" required class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
          <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.form.status', lang)}</label>
            <select name="status" class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm">
              <option value="draft">{t('quotes.status.draft', lang)}</option><option value="sent">{t('quotes.status.sent', lang)}</option><option value="accepted">{t('quotes.status.accepted', lang)}</option><option value="rejected">{t('quotes.status.rejected', lang)}</option><option value="expired">{t('quotes.status.expired', lang)}</option>
            </select>
          </div>
        </div>
        <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.form.client', lang)}</label><input name="clientId" placeholder={t('quotes.form.clientPlaceholder', lang)} class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.form.issueDate', lang)}</label><input name="issueDate" type="date" required class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
          <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.form.validUntil', lang)}</label><input name="validUntil" type="date" required class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>
        </div>
        <div class="space-y-1"><label class="text-sm font-medium">{t('quotes.form.taxRate', lang)}</label><input name="taxRate" type="number" step="0.01" value="20" class="flex h-9 w-full rounded-md border border-input bg-background px-3 text-sm" /></div>

        <div class="space-y-2">
          <div class="flex items-center justify-between"><label class="text-sm font-medium">{t('quotes.form.lines', lang)}</label><button type="button" id="add-line" class="text-xs text-primary hover:underline">+ {t('quotes.form.addLine', lang)}</button></div>
          <div id="lines-container" class="space-y-2"></div>
        </div>

        <div class="grid grid-cols-3 gap-4 bg-muted/50 rounded-md p-3 text-sm">
          <div>{t('quotes.form.subtotal', lang)} : <span id="calc-subtotal">0.00</span> €</div>
          <div>{taxLabel} : <span id="calc-tax">0.00</span> €</div>
          <div class="font-bold">{t('quotes.form.totalTTC', lang)} : <span id="calc-total">0.00</span> €</div>
        </div>

        <div class="space-y-1"><label class="text-sm font-medium">{t('common.notes', lang)}</label><textarea name="notes" rows="2" class="flex w-full rounded-md border border-input bg-background px-3 py-2 text-sm"></textarea></div>

        <div class="flex gap-2 pt-2">
          <button type="submit" class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">{t('common.save', lang)}</button>
          <button type="button" data-close class="inline-flex items-center rounded-md border border-input px-4 py-2 text-sm font-medium hover:bg-muted">{t('common.cancel', lang)}</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline define:vars={{ i18n }}>
    const API=(a,b)=>fetch(`/_actions/${a}`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)}).then(r=>r.json());
    function openD(){document.getElementById('edit-dialog')?.classList.remove('hidden')}function closeD(){document.getElementById('edit-dialog')?.classList.add('hidden')}
    document.querySelectorAll('[data-close]').forEach(el=>el.addEventListener('click',closeD));
    document.querySelectorAll('[data-close-convert]').forEach(el=>el.addEventListener('click',()=>document.getElementById('convert-dialog')?.classList.add('hidden')));

    let currentPage=1,currentStatus='';
    let result={items:[],total:0,totalPages:0};

    const statusLabels={draft:i18n.statusDraft,sent:i18n.statusSent,accepted:i18n.statusAccepted,rejected:i18n.statusRejected,expired:i18n.statusExpired,converted:i18n.statusConverted};
    const statusColors={draft:'bg-gray-100 text-gray-800',sent:'bg-blue-100 text-blue-800',accepted:'bg-green-100 text-green-800',rejected:'bg-red-100 text-red-800',expired:'bg-yellow-100 text-yellow-800',converted:'bg-purple-100 text-purple-800'};

    document.querySelectorAll('#status-filters button').forEach(btn=>{
      btn.addEventListener('click',()=>{
        document.querySelectorAll('#status-filters button').forEach(b=>{b.classList.remove('bg-primary','text-primary-foreground');b.classList.add('hover:bg-muted')});
        btn.classList.add('bg-primary','text-primary-foreground');btn.classList.remove('hover:bg-muted');
        currentStatus=btn.dataset.status;currentPage=1;load();
      });
    });

    async function load(){
      const p={page:currentPage,limit:20};if(currentStatus)p.status=currentStatus;
      const r=await API('listQuotes',p);result=r.data??r;render();
    }
    function render(){
      const tbody=document.getElementById('data-tbody'),empty=document.getElementById('data-empty');
      const items=result.items||[];
      if(!items.length){tbody.innerHTML='';empty.classList.remove('hidden');document.getElementById('pagination').innerHTML='';return;}
      empty.classList.add('hidden');
      tbody.innerHTML=items.map(r=>`<tr class="border-b border-border hover:bg-muted/50">
        <td class="px-4 py-3 font-medium">${escapeHtml(r.quoteNumber)}</td>
        <td class="px-4 py-3 text-xs">${escapeHtml(r.clientId||'—')}</td>
        <td class="px-4 py-3"><span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[r.status]||''}">${escapeHtml(statusLabels[r.status]||r.status)}</span></td>
        <td class="px-4 py-3">${escapeHtml(r.issueDate||'')}</td>
        <td class="px-4 py-3">${escapeHtml(r.validUntil||'')}</td>
        <td class="px-4 py-3 text-right font-medium">${escapeHtml(r.total||'0')} €</td>
        <td class="px-4 py-3 space-x-2">
          <button onclick="edit('${escapeHtml(r.id)}')" class="text-xs text-primary hover:underline">${i18n.edit}</button>
          ${r.status!=='converted'?`<button onclick="convertQ('${escapeHtml(r.id)}')" class="text-xs text-green-600 hover:underline">${i18n.convertToInvoice}</button>`:''}
          <button onclick="del('${escapeHtml(r.id)}')" class="text-xs text-destructive hover:underline">${i18n.delete}</button>
        </td></tr>`).join('');
      document.getElementById('pagination').innerHTML=`<span>${result.total||0} ${i18n.countSuffix}</span><div class="flex gap-2">${currentPage>1?`<button onclick="goPage(${currentPage-1})" class="text-xs text-primary hover:underline">← ${i18n.previous}</button>`:''}${(result.totalPages||0)>currentPage?`<button onclick="goPage(${currentPage+1})" class="text-xs text-primary hover:underline">${i18n.next} →</button>`:''}</div>`;
    }
    window.goPage=p=>{currentPage=p;load()};

    // Line items
    let lineIdx=0;
    function addLine(desc='',qty='1',price='',total=''){
      const i=lineIdx++;
      const div=document.createElement('div');div.className='grid grid-cols-[1fr_60px_80px_80px_30px] gap-2 items-center';div.dataset.line=i;
      div.innerHTML=`<input name="line_desc_${i}" placeholder="${i18n.formDescPlaceholder}" value="${escapeHtml(desc)}" required class="flex h-8 w-full rounded-md border border-input bg-background px-2 text-sm"><input name="line_qty_${i}" type="number" step="0.01" min="0" value="${escapeHtml(qty)}" class="flex h-8 w-full rounded-md border border-input bg-background px-2 text-sm" onchange="recalc()"><input name="line_price_${i}" type="number" step="0.01" min="0" value="${escapeHtml(price)}" placeholder="${i18n.formPricePlaceholder}" class="flex h-8 w-full rounded-md border border-input bg-background px-2 text-sm" onchange="recalc()"><span class="text-sm text-right line-total">${escapeHtml(total||'0.00')}</span><button type="button" onclick="this.parentElement.remove();recalc()" class="text-destructive text-xs">✕</button>`;
      document.getElementById('lines-container').appendChild(div);recalc();
    }
    document.getElementById('add-line')?.addEventListener('click',()=>addLine());

    window.recalc=function(){
      let sub=0;
      document.querySelectorAll('#lines-container > div').forEach(div=>{
        const qty=parseFloat(div.querySelector('[name^=line_qty]')?.value||'0');
        const price=parseFloat(div.querySelector('[name^=line_price]')?.value||'0');
        const t=qty*price;sub+=t;
        div.querySelector('.line-total').textContent=t.toFixed(2);
      });
      const rate=parseFloat(document.querySelector('[name=taxRate]')?.value||'20');
      const tax=sub*rate/100;
      document.getElementById('calc-subtotal').textContent=sub.toFixed(2);
      document.getElementById('calc-tax').textContent=tax.toFixed(2);
      document.getElementById('calc-total').textContent=(sub+tax).toFixed(2);
    };

    function clearLines(){document.getElementById('lines-container').innerHTML='';lineIdx=0;}

    document.getElementById('btn-add')?.addEventListener('click',()=>{
      const f=document.getElementById('edit-form');f.reset();f.querySelector('[name=id]').value='';
      f.querySelector('[name=issueDate]').value=new Date().toISOString().slice(0,10);
      f.querySelector('[name=validUntil]').value=new Date(Date.now()+30*86400000).toISOString().slice(0,10);
      clearLines();addLine();
      document.getElementById('dialog-title').textContent=i18n.newTitle;openD();
    });

    window.edit=async function(id){
      const r=(result.items||[]).find(x=>x.id===id);if(!r)return;
      const f=document.getElementById('edit-form');
      f.querySelector('[name=id]').value=r.id;f.quoteNumber.value=r.quoteNumber;
      f.status.value=r.status;f.clientId.value=r.clientId||'';
      f.issueDate.value=r.issueDate;f.validUntil.value=r.validUntil;
      f.taxRate.value=r.taxRate||'20';f.notes.value=r.notes||'';
      clearLines();
      // Load existing quote line items
      const itemsRes = await API('listQuoteItems', { quoteId: r.id });
      const items = itemsRes.data ?? itemsRes ?? [];
      if (items.length > 0) {
        items.forEach(item => addLine(item.description, item.quantity, item.unitPrice, parseFloat(item.total||'0').toFixed(2)));
      } else {
        addLine();
      }
      document.getElementById('dialog-title').textContent=i18n.editTitle;openD();
    };

    document.getElementById('edit-form')?.addEventListener('submit',async e=>{
      e.preventDefault();const f=e.target;
      const id=f.querySelector('[name=id]').value||undefined;
      const items=[];
      document.querySelectorAll('#lines-container > div').forEach((div,i)=>{
        const desc=div.querySelector('[name^=line_desc]')?.value;
        const qty=div.querySelector('[name^=line_qty]')?.value||'1';
        const price=div.querySelector('[name^=line_price]')?.value||'0';
        const t=(parseFloat(qty)*parseFloat(price)).toFixed(2);
        if(desc)items.push({description:desc,quantity:qty,unitPrice:price,total:t,sortOrder:i});
      });
      const sub=items.reduce((s,i)=>s+parseFloat(i.total),0);
      const rate=parseFloat(f.taxRate.value||'20');const tax=sub*rate/100;
      await API('saveQuote',{id,quoteNumber:f.quoteNumber.value,clientId:f.clientId.value||undefined,status:f.status.value,issueDate:f.issueDate.value,validUntil:f.validUntil.value,subtotal:sub.toFixed(2),taxRate:rate.toString(),taxAmount:tax.toFixed(2),total:(sub+tax).toFixed(2),notes:f.notes.value||undefined,items});
      closeD();load();
    });

    window.convertQ=function(id){
      const cf=document.getElementById('convert-form');cf.reset();
      cf.querySelector('[name=quoteId]').value=id;
      cf.querySelector('[name=dueDate]').value=new Date(Date.now()+30*86400000).toISOString().slice(0,10);
      document.getElementById('convert-dialog')?.classList.remove('hidden');
    };
    document.getElementById('convert-form')?.addEventListener('submit',async e=>{
      e.preventDefault();const f=e.target;
      await API('convertQuoteToInvoice',{quoteId:f.querySelector('[name=quoteId]').value,invoiceNumber:f.invoiceNumber.value,dueDate:f.dueDate.value});
      document.getElementById('convert-dialog')?.classList.add('hidden');load();
    });

    window.del=async id=>{if(!confirm(i18n.confirmDelete))return;await API('deleteQuote',{id});load()};
    load();
  </script>
</AdminLayout>
