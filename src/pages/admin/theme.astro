---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { t } from '@/lib/i18n';
export const prerender = false;
const lang = 'fr';
const i18n = {
  noSettings: t('settings.noSettings', lang),
};
---

<AdminLayout title={t('theme.title', lang)} activeNav="theme" lang={lang}>
  <div class="space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <h1 class="text-2xl font-bold tracking-tight">{t('theme.title', lang)}</h1>
      <p class="text-muted-foreground">{t('theme.subtitle', lang)}</p>
      <div class="flex items-center gap-2 sm:ml-auto">
        <span id="pending-badge" class="hidden rounded-full border border-amber-300 bg-amber-50 px-2.5 py-1 text-xs font-medium text-amber-800"></span>
        <button id="btn-reset" type="button" class="inline-flex items-center rounded-md border border-input px-3 py-2 text-sm font-medium hover:bg-muted disabled:opacity-50" disabled>
          Annuler
        </button>
        <button id="btn-save-theme" type="button" class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 disabled:opacity-60" disabled>
          Sauvegarder le theme
        </button>
      </div>
    </div>

    <div id="loading" class="p-8 text-center text-muted-foreground">{t('common.loading', lang)}</div>

    <div id="theme-form" class="hidden space-y-6">
      <div class="rounded-xl border border-border bg-card p-4 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Variables essentielles</h2>
        <p class="mt-1 text-sm text-muted-foreground">Ces valeurs surchargent les couleurs du mode <strong>clair uniquement</strong>. Le mode sombre possède ses propres valeurs fixes dans le CSS. Les polices de caractères sont gérées séparément et ne sont pas modifiables ici.</p>
      </div>

      <div id="categories-container" class="space-y-8"></div>

      <div class="rounded-xl border border-border bg-card p-5 shadow-sm">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">Apercu rapide</h3>
        <div id="theme-preview" class="mt-3 rounded-xl border p-5" style="background: var(--background); color: var(--foreground); border-color: var(--border);">
          <p class="text-xs uppercase tracking-wider opacity-70">Brand UI Preview</p>
          <h4 class="mt-2 text-xl font-semibold">Les Rochers Blancs</h4>
          <p class="mt-1 text-sm opacity-80">Apercu direct des couleurs principales et du contraste.</p>
          <div class="mt-4 flex gap-2">
            <button type="button" class="rounded-md px-3 py-2 text-sm font-medium" style="background: var(--primary); color: var(--primary-foreground);">Bouton principal</button>
            <button type="button" class="rounded-md border px-3 py-2 text-sm font-medium" style="border-color: var(--border); color: var(--foreground); background: transparent;">Secondaire</button>
            <button type="button" class="rounded-md px-3 py-2 text-sm font-medium" style="background: var(--accent); color: var(--accent-foreground);">Accent or</button>
          </div>
        </div>
      </div>

      <div class="border-t border-border pt-6 space-y-4">
        <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider">{t('settings.addSetting', lang)}</h3>
        <div class="grid grid-cols-4 gap-4">
          <input id="new-key" placeholder={t('settings.form.keyPlaceholder', lang)} class="flex h-9 rounded-md border border-input bg-background px-3 text-sm" />
          <input id="new-value" placeholder={t('settings.form.value', lang)} class="flex h-9 rounded-md border border-input bg-background px-3 text-sm" />
          <select id="new-type" class="flex h-9 rounded-md border border-input bg-background px-3 text-sm">
            <option value="color">Couleur</option><option value="text">Texte</option><option value="number">Nombre</option><option value="font">Police</option>
          </select>
          <input id="new-category" placeholder={t('settings.form.category', lang)} value="general" class="flex h-9 rounded-md border border-input bg-background px-3 text-sm" />
        </div>
        <button id="btn-add" type="button" class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">+ {t('common.add', lang)}</button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ i18n }}>
    /**
     * Call an Astro action with proper error handling.
     * Throws if response is not ok or if JSON parsing fails.
     */
    async function API(action, payload) {
      const res = await fetch(`/_actions/${action}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error(`API error: ${res.status} ${res.statusText}`);
      const data = await res.json();
      if (data.error) throw new Error(data.error.message || 'Unknown API error');
      return data;
    }

    // Keys must match CSS custom property names exactly (--key in :root).
    // Dark mode values are hardcoded in .dark {} — overrides here apply to light mode only.
    const CORE_THEME_FIELDS = [
      // Colors — Primary
      { key: 'primary', type: 'color', category: 'couleurs', label: 'Couleur primaire (forêt)' },
      { key: 'primary-foreground', type: 'color', category: 'couleurs', label: 'Texte sur couleur primaire' },
      // Colors — Accent
      { key: 'accent', type: 'color', category: 'couleurs', label: 'Couleur accent (or)' },
      { key: 'accent-foreground', type: 'color', category: 'couleurs', label: 'Texte sur accent' },
      // Colors — Background / Surface
      { key: 'background', type: 'color', category: 'couleurs', label: 'Fond global' },
      { key: 'foreground', type: 'color', category: 'couleurs', label: 'Texte principal' },
      { key: 'card', type: 'color', category: 'couleurs', label: 'Fond des cartes' },
      { key: 'muted', type: 'color', category: 'couleurs', label: 'Surface atténuée' },
      { key: 'muted-foreground', type: 'color', category: 'couleurs', label: 'Texte atténué' },
      // Colors — Borders
      { key: 'border', type: 'color', category: 'couleurs', label: 'Couleur des bordures' },
      // Alpine brand colors
      { key: 'gold', type: 'color', category: 'marque', label: 'Or (gold)' },
      { key: 'forest', type: 'color', category: 'marque', label: 'Vert forêt' },
      { key: 'wood', type: 'color', category: 'marque', label: 'Bois (wood)' },
      { key: 'cream', type: 'color', category: 'marque', label: 'Crème' },
      // Shape
      { key: 'radius', type: 'text', category: 'forme', label: 'Rayon de base (ex: 0.5rem) — tous les autres en dérivent' },
      // Shadows
      { key: 'shadow-soft', type: 'text', category: 'effets', label: 'Ombre douce' },
      { key: 'shadow-medium', type: 'text', category: 'effets', label: 'Ombre moyenne' },
    ];

    let settings = [];
    const pendingValues = new Map();

    /**
     * Find a setting by its key.
     */
    function byKey(key) {
      return settings.find(s => s.settingKey === key);
    }

    /**
     * Update toolbar button states and pending changes badge.
     */
    function updateToolbar() {
      const hasChanges = pendingValues.size > 0;
      const saveBtn = document.getElementById('btn-save-theme');
      const resetBtn = document.getElementById('btn-reset');
      const badge = document.getElementById('pending-badge');
      
      if (saveBtn) saveBtn.disabled = !hasChanges;
      if (resetBtn) resetBtn.disabled = !hasChanges;
      if (badge) {
        badge.classList.toggle('hidden', !hasChanges);
        badge.textContent = hasChanges ? `${pendingValues.size} changement(s) en attente` : '';
      }
    }

    /**
     * Load theme settings from API and render form.
     */
    async function load() {
      try {
        const res = await API('listThemeSettings', {});
        settings = res.data ?? res ?? [];
        pendingValues.clear();
        ensureCoreFields();
        render();
        updateToolbar();
      } catch (err) {
        showToast(`Erreur de chargement: ${err.message}`, 'destructive');
      }
    }

    /**
     * Ensure all core theme fields exist in settings array.
     * Creates placeholder entries with default values if missing.
     */
    function ensureCoreFields() {
      const existing = new Set(settings.map(s => s.settingKey));
      CORE_THEME_FIELDS.forEach(f => {
        if (existing.has(f.key)) return;
        settings.push({
          settingKey: f.key,
          settingValue: f.type === 'color' ? '#000000' : '',
          settingType: f.type,
          category: f.category,
        });
      });
    }

    /**
     * Apply pending theme variable overrides as inline CSS on the preview block.
     * Only overrides values that are pending — already-set CSS vars come from :root.
     */
    function applyPreview() {
      const preview = document.getElementById('theme-preview');
      if (!preview) return;

      // Color/text vars applied directly to preview element
      const colorKeys = ['primary', 'primary-foreground', 'accent', 'accent-foreground',
        'background', 'foreground', 'card', 'muted', 'muted-foreground', 'border',
        'gold', 'forest', 'wood', 'cream'];

      colorKeys.forEach(key => {
        const val = pendingValues.get(key);
        if (val) preview.style.setProperty(`--${key}`, val);
        else preview.style.removeProperty(`--${key}`);
      });

      const radius = pendingValues.get('radius');
      if (radius) preview.style.setProperty('--radius', radius);
      else preview.style.removeProperty('--radius');

      const shadow = pendingValues.get('shadow-soft');
      preview.style.boxShadow = shadow || '';
    }

    /**
     * Render theme settings into categorized cards with color pickers and text inputs.
     */
    function render() {
      document.getElementById('loading')?.classList.add('hidden');
      document.getElementById('theme-form')?.classList.remove('hidden');

      const categories = {};
      (settings || []).forEach(s => {
        const cat = s.category || 'general';
        if (!categories[cat]) categories[cat] = [];
        categories[cat].push(s);
      });

      const container = document.getElementById('categories-container');
      const cats = Object.keys(categories).sort();
      if (!cats.length) {
        container.innerHTML = `<p class="text-muted-foreground">${escapeHtml(i18n.noSettings)}</p>`;
        return;
      }

      container.innerHTML = cats.map(cat => `
        <div class="rounded-xl border border-border bg-card shadow-sm overflow-hidden">
          <div class="border-b border-border bg-muted/50 px-4 py-3">
            <h3 class="text-sm font-semibold uppercase tracking-wider">${escapeHtml(cat)}</h3>
          </div>
          <div class="p-4 space-y-3">
            ${categories[cat].map(s => `
              <div class="flex items-center gap-4">
                <label class="text-sm font-medium w-64 shrink-0">${escapeHtml(s.settingKey)}</label>
                ${s.settingType === 'color'
                  ? `
                    <input type="color" value="${escapeHtml(s.settingValue || '#000000')}" 
                      oninput="setThemeValue('${escapeHtml(s.settingKey)}',this.value)" 
                      class="h-9 w-12 rounded border border-input cursor-pointer" />
                    <span class="text-xs text-muted-foreground">${escapeHtml(s.settingValue || '')}</span>
                  `
                  : `
                    <input type="text" value="${escapeHtml(s.settingValue || '')}" 
                      oninput="setThemeValue('${escapeHtml(s.settingKey)}',this.value)" 
                      class="flex h-9 w-full max-w-xl rounded-md border border-input bg-background px-3 text-sm" />
                  `
                }
              </div>
            `).join('')}
          </div>
        </div>
      `).join('');
      
      applyPreview();
    }

    /**
     * Track a theme value change and update UI state and preview.
     */
    window.setThemeValue = function (key, value) {
      const setting = byKey(key);
      if (!setting) return;
      if ((setting.settingValue || '') === value) {
        pendingValues.delete(key);
      } else {
        pendingValues.set(key, value);
      }
      updateToolbar();
      applyPreview();
    };

    /**
     * Reset all changes and restore original state.
     */
    document.getElementById('btn-reset')?.addEventListener('click', () => {
      pendingValues.clear();
      render();
      updateToolbar();
    });

    /**
     * Save all pending theme changes via batch API call.
     */
    document.getElementById('btn-save-theme')?.addEventListener('click', async () => {
      if (!pendingValues.size) return;
      const btn = document.getElementById('btn-save-theme');
      btn.disabled = true;
      btn.textContent = 'Sauvegarde...';
      try {
        const updates = settings
          .filter(s => pendingValues.has(s.settingKey))
          .map(s => API('saveThemeSetting', {
            settingKey: s.settingKey,
            settingValue: pendingValues.get(s.settingKey),
            settingType: s.settingType || 'text',
            category: s.category || 'general',
          }));
        await Promise.all(updates);
        showToast('Theme sauvegarde', 'success');
        await load();
      } catch (err) {
        showToast(`Erreur: ${err.message}`, 'destructive');
        btn.disabled = false;
        btn.textContent = 'Sauvegarder le theme';
      }
    });

    /**
     * Add a custom theme variable.
     */
    document.getElementById('btn-add')?.addEventListener('click', async () => {
      const key = document.getElementById('new-key')?.value?.trim();
      const value = document.getElementById('new-value')?.value?.trim();
      const type = document.getElementById('new-type')?.value || 'color';
      const category = document.getElementById('new-category')?.value?.trim() || 'general';
      if (!key) {
        showToast('Cle requise', 'destructive');
        return;
      }
      try {
        await API('saveThemeSetting', {
          settingKey: key,
          settingValue: value || '',
          settingType: type,
          category,
        });
        document.getElementById('new-key').value = '';
        document.getElementById('new-value').value = '';
        showToast('Variable ajoutee', 'success');
        await load();
      } catch (err) {
        showToast(`Erreur: ${err.message}`, 'destructive');
      }
    });

    // Initialize on page load
    load();
  </script>
</AdminLayout>
