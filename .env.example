# ---- Required ----

# PostgreSQL connection string
# Production example (managed PostgreSQL with TLS)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# better-auth — secret must be at least 32 random characters
BETTER_AUTH_SECRET=your-random-secret-at-least-32-chars

# better-auth — public URL of the application (must match the final public domain)
# Example prod: https://lesrochersblancs.fr
# Docker Compose production derives this automatically from APP_DOMAIN.
BETTER_AUTH_URL=http://localhost

# ---- Optional ----

# Override site URL for SEO canonical/OG (default: https://lesrochersblancs.fr)
# SITE_URL=https://lesrochersblancs.fr

# Runtime upload storage directory (default: storage/uploads)
# UPLOADS_DIR=storage/uploads

# Opt-in only: allow fallback reads from legacy public/uploads when UPLOADS_DIR is configured
# ALLOW_LEGACY_UPLOAD_FALLBACK=false

# Migration startup retry window for docker-compose (defaults shown)
# DB_WAIT_MAX_ATTEMPTS=30
# DB_WAIT_DELAY_MS=2000

# Server bind address and port (default: 0.0.0.0:4321)
# HOST=0.0.0.0
# PORT=4321

# ---- Production (Docker) ----

# Public domain used by the reverse proxy (Caddy)
# Host only, without https:// (example: lesrochersblancs.fr)
# Also used to derive BETTER_AUTH_URL inside docker-compose.
# APP_DOMAIN=lesrochersblancs.fr

# Optional password for the bundled local Postgres profile (`docker compose --profile local-db ...`)
# POSTGRES_PASSWORD=strong-random-password

# Local Docker DB example if you enable the `local-db` profile:
# DATABASE_URL=postgresql://postgres:strong-random-password@db:5432/rochers_blancs?sslmode=disable

# ADMIN_EMAIL=admin@lesrochersblancs.fr
# ADMIN_PASSWORD=Admin123!
# ADMIN_NAME=Administrateur